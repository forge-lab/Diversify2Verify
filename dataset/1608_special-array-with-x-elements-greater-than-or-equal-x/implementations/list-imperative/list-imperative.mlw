  let test_test_013 () : bool =
    let nums = Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 Nil))))) in
    let r = special_array_with_x_elements_greater_than_or_equal_x_list nums in
    r = (-1)

  let test_test_014 () : bool =
    let nums = Cons 0 Nil in
