  let test_test_017 () : bool =
    let nums = Cons 3 (Cons 5 Nil) in
    let r = special_array_with_x_elements_greater_than_or_equal_x_list nums in
    r = 2

  let test_test_018 () : bool =
    let nums = Cons 1000 (Cons 999 (Cons 998 (Cons 997 (Cons 996 Nil)))) in
    let r = special_array_with_x_elements_greater_than_or_equal_x_list nums in
    r = 5

  let test_test_019 () : bool =
    let nums = Cons 1 (Cons 2 (Cons 3 (Cons 3 (Cons 3 Nil)))) in
    let r = special_array_with_x_elements_greater_than_or_equal_x_list nums in
    r = 3

