  let test_test_015 () : bool =
    let nums = Cons 100 (Cons 200 (Cons 300 (Cons 400 (Cons 500 Nil)))) in
    let r = special_array_with_x_elements_greater_than_or_equal_x_list nums in
    r = 5

  let test_test_016 () : bool =
    let nums = Cons 0 (Cons 4 (Cons 3 (Cons 0 (Cons 4 Nil)))) in
    let r = special_array_with_x_elements_greater_than_or_equal_x_list nums in
