module SpecialArrayWithXElementsGreaterThanOrEqualX_List_Imperative

  use int.Int
  use list.List
  use ref.Ref

  let list_length (nums: list int) : int =
    let n = ref 0 in
    let cur = ref nums in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons _ ys ->
          n := !n + 1;
          cur := ys
      end
    done;
    !n

  let count_ge (nums: list int) (x: int) : int =
    let count = ref 0 in
    let cur = ref nums in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons y ys ->
          if y >= x then count := !count + 1;
          cur := ys
      end
    done;
    !count

  let special_array_with_x_elements_greater_than_or_equal_x_list (nums: list int) : int =
    let n = list_length nums in
    let candidate = ref 0 in
    let result = ref (-1) in
    while !candidate <= n do
      let matching = count_ge nums !candidate in
      if matching = !candidate then result := !candidate;
      candidate := !candidate + 1
    done;
    !result

  let test_test_000 () : bool =
    let nums = Cons 6 (Cons 5 (Cons 4 (Cons 3 (Cons 2 (Cons 1 Nil))))) in
    let r = special_array_with_x_elements_greater_than_or_equal_x_list nums in
    r = (-1)

  let test_test_001 () : bool =
    let nums =
      Cons 100 (Cons 100 (Cons 100 (Cons 100 (Cons 100
        (Cons 100 (Cons 100 (Cons 100 (Cons 100 (Cons 100 Nil)))))))))
    in
    let r = special_array_with_x_elements_greater_than_or_equal_x_list nums in
    r = 10

  let test_test_002 () : bool =
    let nums = Cons 0 (Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 Nil))))) in
    let r = special_array_with_x_elements_greater_than_or_equal_x_list nums in
    r = 3

  let test_test_003 () : bool =
    let nums =
      Cons 0 (Cons 1 (Cons 2 (Cons 3 (Cons 4
        (Cons 5 (Cons 6 (Cons 7 (Cons 8 (Cons 9 (Cons 10 Nil))))))))))
    in
    let r = special_array_with_x_elements_greater_than_or_equal_x_list nums in
    r = (-1)

  let test_test_004 () : bool =
    let nums = Cons 100 (Cons 200 (Cons 300 (Cons 400 (Cons 500 Nil)))) in
    let r = special_array_with_x_elements_greater_than_or_equal_x_list nums in
    r = 5

  let test_test_005 () : bool =
