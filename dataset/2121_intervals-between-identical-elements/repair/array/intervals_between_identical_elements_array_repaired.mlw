    assert { length expected = 8 };
    assert { arr[0] = 1 /\ arr[1] = 1 };
    assert { arr[2] = 2 /\ arr[3] = 2 };
    assert { arr[4] = 3 /\ arr[5] = 3 };
    assert { arr[6] = 4 /\ arr[7] = 4 };
    assert { interval_contribution arr 0 1 = 1 };
    assert { interval_contribution arr 2 3 = 1 };
    assert { interval_contribution arr 4 5 = 1 };
    assert { interval_contribution arr 6 7 = 1 };
    assert { interval_sum_at arr 0 = 1 };
    assert { interval_sum_at arr 1 = 1 };
    assert { interval_sum_at arr 2 = 1 };
    assert { interval_sum_at arr 3 = 1 };
    assert { interval_sum_at arr 4 = 1 };
    assert { interval_sum_at arr 5 = 1 };
    assert { interval_sum_at arr 6 = 1 };
    assert { interval_sum_at arr 7 = 1 };
    assert { expected_at arr expected 0 };
    assert { expected_at arr expected 1 };
    assert { expected_at arr expected 2 };
    assert { expected_at arr expected 3 };
    assert { expected_at arr expected 4 };
    assert { expected_at arr expected 5 };
    assert { expected_at arr expected 6 };
    assert { expected_at arr expected 7 };
    assert {
      forall i: int. 0 <= i < length arr ->
        i = 0 \/ i = 1 \/ i = 2 \/ i = 3 \/
        i = 4 \/ i = 5 \/ i = 6 \/ i = 7
    };
    assert { intervals_between_identical_elements_array_spec arr expected }

  let lemma test_010_python_assertions () =
    let arr = init 7 [|2; 1; 3; 1; 2; 3; 3|] in
    let expected = init 7 [|4; 2; 7; 2; 4; 4; 5|] in
    assert { length arr = 7 };
    assert { length expected = 7 };
    assert { arr[0] = 2 /\ arr[4] = 2 };
    assert { arr[1] = 1 /\ arr[3] = 1 };
    assert { arr[2] = 3 /\ arr[5] = 3 /\ arr[6] = 3 };
    assert { interval_contribution arr 0 4 = 4 };
    assert { interval_contribution arr 1 3 = 2 };
    assert { interval_contribution arr 2 5 = 3 };
    assert { interval_contribution arr 2 6 = 4 };
    assert { interval_contribution arr 5 2 = 3 };
    assert { interval_contribution arr 5 6 = 1 };
    assert { interval_sum_at arr 0 = 4 };
    assert { interval_sum_at arr 1 = 2 };
    assert { interval_sum_at arr 2 = 7 };
    assert { interval_sum_at arr 3 = 2 };
    assert { interval_sum_at arr 4 = 4 };
    assert { interval_sum_at arr 5 = 4 };
    assert { interval_sum_at arr 6 = 5 };
    assert { expected_at arr expected 0 };
    assert { expected_at arr expected 1 };
    assert { expected_at arr expected 2 };
    assert { expected_at arr expected 3 };
    assert { expected_at arr expected 4 };
    assert { expected_at arr expected 5 };
    assert { expected_at arr expected 6 };
    assert {
      forall i: int. 0 <= i < length arr ->
        i = 0 \/ i = 1 \/ i = 2 \/ i = 3 \/
        i = 4 \/ i = 5 \/ i = 6
    };
    assert { intervals_between_identical_elements_array_spec arr expected }

  let lemma test_035_python_assertions () =
    let arr = init 9 [|5; 2; 5; 5; 3; 2; 5; 3; 5|] in
    let expected = init 9 [|19; 4; 13; 12; 3; 4; 15; 3; 21|] in
    assert { length arr = 9 };
    assert { length expected = 9 };
    assert { arr[0] = 5 /\ arr[2] = 5 /\ arr[3] = 5 /\ arr[6] = 5 /\ arr[8] = 5 };
    assert { arr[1] = 2 /\ arr[5] = 2 };
    assert { arr[4] = 3 /\ arr[7] = 3 };
    assert { interval_contribution arr 0 8 = 8 };
    assert { interval_contribution arr 1 5 = 4 };
    assert { interval_contribution arr 4 7 = 3 };
    assert { interval_contribution arr 8 0 = 8 };
    assert { interval_sum_at arr 0 = 19 };
    assert { interval_sum_at arr 1 = 4 };
    assert { interval_sum_at arr 2 = 13 };
    assert { interval_sum_at arr 3 = 12 };
    assert { interval_sum_at arr 4 = 3 };
    assert { interval_sum_at arr 5 = 4 };
    assert { interval_sum_at arr 6 = 15 };
    assert { interval_sum_at arr 7 = 3 };
    assert { interval_sum_at arr 8 = 21 };
    assert { expected_at arr expected 0 };
    assert { expected_at arr expected 1 };
    assert { expected_at arr expected 2 };
    assert { expected_at arr expected 3 };
    assert { expected_at arr expected 4 };
    assert { expected_at arr expected 5 };
    assert { expected_at arr expected 6 };
    assert { expected_at arr expected 7 };
    assert { expected_at arr expected 8 };
    assert {
      forall i: int. 0 <= i < length arr ->
        i = 0 \/ i = 1 \/ i = 2 \/ i = 3 \/ i = 4 \/
        i = 5 \/ i = 6 \/ i = 7 \/ i = 8
    };
    assert { intervals_between_identical_elements_array_spec arr expected }

end
