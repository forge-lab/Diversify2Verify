    assert { length expected = 5 };
    assert { arr[0] = 5 };
    assert { arr[1] = 5 };
    assert { arr[2] = 5 };
    assert { arr[3] = 5 };
    assert { arr[4] = 5 };
    assert { interval_contribution arr 0 4 = 4 };
    assert { interval_contribution arr 2 0 = 2 };
    assert { interval_contribution arr 2 4 = 2 };
    assert { interval_sum_at arr 0 = 10 };
    assert { interval_sum_at arr 1 = 7 };
    assert { interval_sum_at arr 2 = 6 };
    assert { interval_sum_at arr 3 = 7 };
    assert { interval_sum_at arr 4 = 10 };
    assert { expected_at arr expected 0 };
    assert { expected_at arr expected 1 };
    assert { expected_at arr expected 2 };
    assert { expected_at arr expected 3 };
    assert { expected_at arr expected 4 };
    assert {
      forall i: int. 0 <= i < length arr ->
        i = 0 \/ i = 1 \/ i = 2 \/ i = 3 \/ i = 4
    };
    assert { intervals_between_identical_elements_array_spec arr expected }

  let lemma test_009_python_assertions () =
