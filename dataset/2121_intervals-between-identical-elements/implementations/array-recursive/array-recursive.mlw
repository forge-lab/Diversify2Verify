module IntervalsBetweenIdenticalElements_Array_Recursive_Implementation

  use int.Int
  use int.Abs
  use array.Array
  use array.Init

  predicate valid_input (arr: array int) =
    1 <= length arr <= 100000 /\
    forall i: int. 0 <= i < length arr -> 1 <= arr[i] <= 100000

  let interval_contribution (arr: array int) (i: int) (j: int) : int =
    if arr[i] = arr[j] then abs (i - j) else 0

  let rec interval_sum_from (arr: array int) (i: int) (j: int) : int
    variant { length arr - j }
  =
    if j >= length arr then
      0
    else
      interval_contribution arr i j + interval_sum_from arr i (j + 1)

  let rec fill_result (arr: array int) (res: array int) (i: int) : unit
    variant { length arr - i }
  =
    if i >= length arr then
      ()
    else begin
      res[i] <- interval_sum_from arr i 0;
      fill_result arr res (i + 1)
    end

  let intervals_between_identical_elements_array (arr: array int) : array int =
    let n = length arr in
    if n = 0 then
      make 0 0
    else
      let res = make n 0 in
      fill_result arr res 0;
      res

  let rec arrays_equal_from (a: array int) (b: array int) (i: int) : bool
    variant { length a - i }
  =
    if i >= length a then
      true
    else if a[i] = b[i] then
      arrays_equal_from a b (i + 1)
    else
      false

  let arrays_equal (a: array int) (b: array int) : bool =
    if length a <> length b then
      false
    else
      arrays_equal_from a b 0

  let check_case (arr: array int) (expected: array int) : bool =
    let r = intervals_between_identical_elements_array arr in
    arrays_equal r expected

  let test_test_000 () : bool =
    let arr = init 10 [|100000; 1; 100000; 2; 100000; 3; 100000; 4; 100000; 5|] in
    let expected = init 10 [|20; 0; 14; 0; 12; 0; 14; 0; 20; 0|] in
    check_case arr expected

  let test_test_001 () : bool =
    let arr = init 5 [|5; 4; 3; 2; 1|] in
    let expected = init 5 [|0; 0; 0; 0; 0|] in
    check_case arr expected

  let test_test_002 () : bool =
    let arr = init 11 [|1; 3; 2; 3; 1; 4; 2; 3; 1; 4; 2|] in
    let expected = init 11 [|12; 8; 12; 6; 8; 4; 8; 10; 12; 4; 12|] in
    check_case arr expected

  let test_test_003 () : bool =
