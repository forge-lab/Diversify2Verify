  let test_test_019 () : bool =
    let arr = init 20 [|10; 20; 10; 30; 10; 40; 10; 50; 10; 60; 10; 70; 10; 80; 10; 90; 10; 100; 10; 110|] in
    let expected = init 20 [|90; 0; 74; 0; 62; 0; 54; 0; 50; 0; 50; 0; 54; 0; 62; 0; 74; 0; 90; 0|] in
