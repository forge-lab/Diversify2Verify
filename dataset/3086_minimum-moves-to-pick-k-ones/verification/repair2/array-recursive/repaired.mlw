module MinimumMovesToPickKOnes_Array_Spec

  use int.Int
  use int.Abs
  use array.Array
  use array.Init
  use list.List

  predicate binary_array (nums: array int) =
    forall i: int. 0 <= i < length nums -> nums[i] = 0 \/ nums[i] = 1

  let rec function ones_count_from (nums: array int) (i: int) : int
    requires { 0 <= i <= length nums }
    variant  { length nums - i }
  =
    if i = length nums then 0
    else (if nums[i] = 1 then 1 else 0) + ones_count_from nums (i + 1)

  function ones_count (nums: array int) : int =
    ones_count_from nums 0

  let rec lemma ones_count_from_nonnegative (nums: array int) (i: int)
    requires { 0 <= i <= length nums }
    ensures  { 0 <= ones_count_from nums i }
    variant  { length nums - i }
  =
    if i < length nums then
      ones_count_from_nonnegative nums (i + 1)

  let lemma ones_count_nonnegative (nums: array int)
    ensures { 0 <= ones_count nums }
  =
    ones_count_from_nonnegative nums 0

  let rec function selected_count_from (take: array int) (i: int) : int
    requires { 0 <= i <= length take }
    variant  { length take - i }
  =
    if i = length take then 0
    else (if take[i] = 1 then 1 else 0) + selected_count_from take (i + 1)

  let rec function selected_distance_from (take: array int) (center: int) (i: int) : int
    requires { 0 <= i <= length take }
    variant  { length take - i }
  =
    if i = length take then 0
    else (if take[i] = 1 then abs (i - center) else 0) +
         selected_distance_from take center (i + 1)

  predicate valid_original_selection (nums: array int) (take: array int) =
    length take = length nums /\
    (forall i: int.
       0 <= i < length nums ->
       (take[i] = 0 \/ take[i] = 1) /\ (take[i] = 1 -> nums[i] = 1))

  predicate feasible_input (nums: array int) (k: int) (maxChanges: int) =
    length nums >= 2 /\
    binary_array nums /\
    k >= 1 /\
    maxChanges >= 0 /\
    k <= maxChanges + ones_count nums

  predicate feasible_pickup_plan
    (nums: array int) (k: int) (maxChanges: int)
    (center: int) (take: array int) (changes: int) (moves: int) =
    feasible_input nums k maxChanges /\
    0 <= center < length nums /\
    valid_original_selection nums take /\
    (nums[center] = 1 -> take[center] = 1) /\
    0 <= changes <= maxChanges /\
    selected_count_from take 0 + changes = k /\
    moves = selected_distance_from take center 0 + 2 * changes

  predicate optimal_pickup_cost (nums: array int) (k: int) (maxChanges: int) (result: int) =
    feasible_input nums k maxChanges /\
    (exists center: int. exists take: array int. exists changes: int.
       feasible_pickup_plan nums k maxChanges center take changes result) /\
    (forall center: int. forall take: array int. forall changes: int. forall moves: int.
       feasible_pickup_plan nums k maxChanges center take changes moves -> result <= moves)

  predicate center_pickup_cost
    (nums: array int) (k: int) (maxChanges: int) (center: int) (cost: int) =
    feasible_input nums k maxChanges /\
    0 <= center < length nums /\
    (exists take: array int. exists changes: int.
       feasible_pickup_plan nums k maxChanges center take changes cost) /\
    (forall take: array int. forall changes: int. forall moves: int.
       feasible_pickup_plan nums k maxChanges center take changes moves -> cost <= moves)

  predicate suffix_pickup_cost
    (nums: array int) (k: int) (maxChanges: int) (start: int) (cost: int) =
    feasible_input nums k maxChanges /\
    0 <= start < length nums /\
    (exists center: int. exists take: array int. exists changes: int.
       start <= center < length nums /\
       feasible_pickup_plan nums k maxChanges center take changes cost) /\
    (forall center: int. forall take: array int.
       forall changes: int. forall moves: int.
       start <= center < length nums /\
       feasible_pickup_plan nums k maxChanges center take changes moves ->
       cost <= moves)

  let lemma suffix_at_zero_implies_optimal
    (nums: array int) (k: int) (maxChanges: int) (cost: int)
    requires { suffix_pickup_cost nums k maxChanges 0 cost }
    ensures  { optimal_pickup_cost nums k maxChanges cost }
  =
    assert { feasible_input nums k maxChanges };
    assert { exists center: int. exists take: array int. exists changes: int.
      feasible_pickup_plan nums k maxChanges center take changes cost };
    assert { forall center: int. forall take: array int.
      forall changes: int. forall moves: int.
      feasible_pickup_plan nums k maxChanges center take changes moves ->
      cost <= moves }

  let rec ones_count_exec_from (nums: array int) (i: int) : int
    requires { 0 <= i <= length nums }
    ensures  { result = ones_count_from nums i }
    ensures  { 0 <= result }
    variant  { length nums - i }
  =
    ones_count_from_nonnegative nums i;
    if i = length nums then
      0
    else
      (if nums[i] = 1 then 1 else 0) + ones_count_exec_from nums (i + 1)

  let ones_count_exec (nums: array int) : int
    ensures { result = ones_count nums }
    ensures { 0 <= result }
  =
    ones_count_exec_from nums 0

  let abs_int (x: int) : int
    ensures { result = abs x }
    ensures { result >= 0 }
  =
    if x >= 0 then x else -x

  let rec insert_sorted (x: int) (xs: list int) : list int
    variant { xs }
  =
    match xs with
    | Nil -> Cons x Nil
    | Cons y ys ->
        if x <= y then
          Cons x xs
        else
          Cons y (insert_sorted x ys)
    end

  let rec collect_sorted_distances (nums: array int) (center: int) (i: int) : list int
    requires { 0 <= center < length nums }
    requires { 0 <= i <= length nums }
    variant  { length nums - i }
  =
    if i = length nums then
      Nil
    else
      let tail = collect_sorted_distances nums center (i + 1) in
      if nums[i] = 1 then
        insert_sorted (abs_int (i - center)) tail
      else
        tail

  let rec evaluate_prefixes
    (distances: list int) (k: int) (min_originals: int) (max_originals: int)
    (taken: int) (prefix_cost: int) (best_cost: int) (found: bool) : int
    requires { 0 <= min_originals <= max_originals }
    requires { 0 <= taken <= max_originals }
    variant  { distances }
  =
    let has_candidate =
      if min_originals <= taken then taken <= max_originals else false in
    let current_best =
      if has_candidate then
        let candidate = prefix_cost + 2 * (k - taken) in
        if found then
          if candidate <= best_cost then candidate else best_cost
        else
          candidate
      else
        best_cost in
    let current_found = if has_candidate then true else found in
    if taken = max_originals then
      current_best
    else
      match distances with
      | Nil -> current_best
      | Cons d rest ->
          evaluate_prefixes
            rest k min_originals max_originals (taken + 1) (prefix_cost + d)
            current_best current_found
      end

  let cost_for_center (nums: array int) (k: int) (maxChanges: int) (center: int) : int
    requires { feasible_input nums k maxChanges }
    requires { 0 <= center < length nums }
    ensures  { center_pickup_cost nums k maxChanges center result }
  =
    let distances = collect_sorted_distances nums center 0 in
    let ones_total = ones_count_exec nums in
    assert { ones_total = ones_count nums };
    assert { 0 <= ones_total };
    let min_originals = if k - maxChanges > 0 then k - maxChanges else 0 in
    assert { 0 <= min_originals };
    assert { min_originals <= k };
    assert { min_originals <= ones_total };
    let max_originals = if ones_total < k then ones_total else k in
    assert { 0 <= max_originals };
    assert { max_originals <= k };
    assert { max_originals <= ones_total };
    if ones_total < k then
      assert { max_originals = ones_total }
    else
      assert { max_originals = k };
    assert { min_originals <= max_originals };
    evaluate_prefixes distances k min_originals max_originals 0 0 0 false

  let rec best_center_cost_from (nums: array int) (k: int) (maxChanges: int) (center: int) : int
    requires { feasible_input nums k maxChanges }
    requires { 0 <= center < length nums }
    ensures  { suffix_pickup_cost nums k maxChanges center result }
    variant  { length nums - center }
  =
    let current = cost_for_center nums k maxChanges center in
    assert { center_pickup_cost nums k maxChanges center current };
    if center + 1 = length nums then
      begin
      assert { suffix_pickup_cost nums k maxChanges center current };
      current
      end
    else
      let rest = best_center_cost_from nums k maxChanges (center + 1) in
      assert { suffix_pickup_cost nums k maxChanges (center + 1) rest };
      if current <= rest then
        begin
          assert { exists c: int. exists take: array int. exists changes: int.
            center <= c < length nums /\
            feasible_pickup_plan nums k maxChanges c take changes current };
          assert { forall c: int. forall take: array int.
            forall changes: int. forall moves: int.
            center <= c < length nums /\
            feasible_pickup_plan nums k maxChanges c take changes moves ->
            current <= moves };
          assert { suffix_pickup_cost nums k maxChanges center current };
          current
        end
      else
        begin
          assert { exists c: int. exists take: array int. exists changes: int.
            center <= c < length nums /\
            feasible_pickup_plan nums k maxChanges c take changes rest };
          assert { forall c: int. forall take: array int.
            forall changes: int. forall moves: int.
            center <= c < length nums /\
            feasible_pickup_plan nums k maxChanges c take changes moves ->
            rest <= moves };
          assert { suffix_pickup_cost nums k maxChanges center rest };
          rest
        end

  let minimum_moves_to_pick_k_ones_array (nums: array int) (k: int) (maxChanges: int) : int
    requires { feasible_input nums k maxChanges }
    ensures  { optimal_pickup_cost nums k maxChanges result }
  =
    let result = best_center_cost_from nums k maxChanges 0 in
    assert { feasible_input nums k maxChanges };
    assert { suffix_pickup_cost nums k maxChanges 0 result };
    assert { exists center: int. exists take: array int. exists changes: int.
      feasible_pickup_plan nums k maxChanges center take changes result };
    assert { forall center: int. forall take: array int.
      forall changes: int. forall moves: int.
      feasible_pickup_plan nums k maxChanges center take changes moves ->
      result <= moves };
    suffix_at_zero_implies_optimal nums k maxChanges result;
    assert { optimal_pickup_cost nums k maxChanges result };
    result

end
