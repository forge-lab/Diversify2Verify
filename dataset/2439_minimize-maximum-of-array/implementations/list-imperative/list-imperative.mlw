module MinimizeMaximumOfArray_List_Imperative_Implementation

  use int.Int
  use int.EuclideanDivision
  use list.List
  use ref.Ref

  let minimize_maximum_of_array_list (nums: list int) : int =
    let prefix_sum = ref 0 in
    let prefix_len = ref 0 in
    let best = ref 0 in
    let cur = ref nums in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons x xs ->
          prefix_sum := !prefix_sum + x;
          prefix_len := !prefix_len + 1;
          let candidate = div (!prefix_sum + !prefix_len - 1) !prefix_len in
          if candidate > !best then best := candidate;
          cur := xs
      end
    done;
    !best

  let test_000 () : bool =
    let nums = Cons 1 (Cons 9 (Cons 1 (Cons 9 (Cons 1 Nil)))) in
    let r = minimize_maximum_of_array_list nums in
    r = 5

  let test_001 () : bool =
    let nums = Cons 1 (Cons 1000000000 Nil) in
    let r = minimize_maximum_of_array_list nums in
    r = 500000001

  let test_002 () : bool =
    let nums =
      Cons 1000000000
        (Cons 1000000000
           (Cons 1000000000 (Cons 1000000000 (Cons 1000000000 Nil)))) in
    let r = minimize_maximum_of_array_list nums in
    r = 1000000000

  let test_003 () : bool =
    let nums = Cons 9 (Cons 7 (Cons 5 (Cons 3 (Cons 1 Nil)))) in
    let r = minimize_maximum_of_array_list nums in
    r = 9

  let test_004 () : bool =
    let nums =
      Cons 10
        (Cons 9
           (Cons 8
              (Cons 7
                 (Cons 6 (Cons 5 (Cons 4 (Cons 3 (Cons 2 (Cons 1 Nil))))))))) in
    let r = minimize_maximum_of_array_list nums in
    r = 10

  let test_005 () : bool =
    let nums = Cons 1000000000 (Cons 1000000000 Nil) in
