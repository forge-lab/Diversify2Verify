module LongestIncreasingSubsequence_List_Imperative

  use int.Int
  use list.List
  use ref.Ref

  let longest_increasing_subsequence_list (nums: list int) : int =
    let seen = ref Nil in
    let lengths = ref Nil in
    let best_overall = ref 0 in
    let cur = ref nums in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons x xs ->
          let best_here = ref 1 in
          let prev_nums = ref !seen in
          let prev_lengths = ref !lengths in
          while (match !prev_nums with Nil -> false | Cons _ _ -> true end) do
            match !prev_nums, !prev_lengths with
            | Cons y ys, Cons d ds ->
                (if y < x then
                   let candidate = d + 1 in
                   if candidate > !best_here then best_here := candidate
                 else ());
                prev_nums := ys;
                prev_lengths := ds
            | _, _ ->
                prev_nums := Nil;
                prev_lengths := Nil
            end
          done;
          seen := Cons x !seen;
          lengths := Cons !best_here !lengths;
          (if !best_here > !best_overall then best_overall := !best_here else ());
          cur := xs
      end
    done;
    !best_overall

  let test_000 () : bool =
    let nums = Cons 5 (Cons 4 (Cons 3 (Cons 2 (Cons 1 Nil)))) in
    let r = longest_increasing_subsequence_list nums in
    r = 1

  let test_001 () : bool =
    let nums = Cons 1 Nil in
    let r = longest_increasing_subsequence_list nums in
    r = 1

