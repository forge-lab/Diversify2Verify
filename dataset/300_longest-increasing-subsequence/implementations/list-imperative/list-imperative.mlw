  let test_020 () : bool =
    let nums = Cons 100 (Cons 101 (Cons 102 (Cons 103 (Cons 104 (Cons 105 (Cons 106 (Cons 107 (Cons 108 (Cons 109 (Cons 110 Nil)))))))))) in
    let r = longest_increasing_subsequence_list nums in
