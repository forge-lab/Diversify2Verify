  let test_test_017 () : bool =
    let nums = Cons 1 (Cons 100 (Cons 200 (Cons 300 (Cons 400 (Cons 500 (Cons 600 (Cons 700 (Cons 800 (Cons 900 (Cons 1000 (Nil))))))))))) in
    let r = smallest_range_ii_list nums 100 in
    r = 799

  let test_test_018 () : bool =
    let nums = Cons 1 (Cons 3 (Cons 5 (Cons 7 (Cons 9 (Cons 11 (Cons 13 (Cons 15 (Cons 17 (Cons 19 (Cons 21 (Cons 23 (Cons 25 (Cons 27 (Cons 29 (Cons 31 (Cons 33 (Cons 35 (Cons 37 (Cons 39 (Nil)))))))))))))))))))) in
    let r = smallest_range_ii_list nums 10 in
    r = 18

  let test_test_019 () : bool =
    let nums = Cons 10 (Cons 15 (Cons 20 (Cons 25 (Cons 30 (Cons 35 (Cons 40 (Nil))))))) in
    let r = smallest_range_ii_list nums 5 in
    r = 20

