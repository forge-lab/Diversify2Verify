module SmallestRangeIi_List_Recursive

  use int.Int
  use list.List

  let min2 (a: int) (b: int) : int =
    if a <= b then a else b

  let max2 (a: int) (b: int) : int =
    if a >= b then a else b

  let rec insert_sorted (x: int) (l: list int) : list int
    variant { l }
  =
    match l with
    | Nil -> Cons x Nil
    | Cons y ys ->
        if x <= y then Cons x l else Cons y (insert_sorted x ys)
    end

  let rec sort_list (l: list int) : list int
    variant { l }
  =
    match l with
    | Nil -> Nil
    | Cons x xs -> insert_sorted x (sort_list xs)
    end

  let rec last_value_with_current (current: int) (xs: list int) : int
    variant { xs }
  =
    match xs with
    | Nil -> current
    | Cons y ys -> last_value_with_current y ys
    end

  let rec best_split
    (first: int) (last: int) (k: int) (prev: int) (rest: list int) (best: int) : int
    variant { rest }
  =
    match rest with
    | Nil -> best
    | Cons current tail ->
        let high = max2 (prev + k) (last - k) in
        let low = min2 (first + k) (current - k) in
        let candidate = high - low in
        let next_best = min2 best candidate in
        best_split first last k current tail next_best
    end

  let smallest_range_ii_list (nums: list int) (k: int) : int =
    match sort_list nums with
    | Nil -> 0
    | Cons first rest ->
        let last = last_value_with_current first rest in
        let initial = last - first in
        best_split first last k first rest initial
    end

  let test_test_000 () : bool =
    let nums = Cons 0 (Cons 10 (Nil)) in
    let r = smallest_range_ii_list nums 2 in
    r = 6

  let test_test_001 () : bool =
    let nums = Cons 1 (Cons 5 (Cons 8 (Nil))) in
    let r = smallest_range_ii_list nums 2 in
    r = 3

  let test_test_002 () : bool =
    let nums = Cons 6 (Cons 3 (Cons 4 (Cons 7 (Nil)))) in
    let r = smallest_range_ii_list nums 3 in
    r = 4

  let test_test_003 () : bool =
