module CountOfInterestingSubarrays_List_Recursive_Implementation

  use int.Int
  use int.EuclideanDivision
  use list.List

  let interesting_element_indicator (x: int) (modulo: int) (k: int) : int =
    if 0 < modulo then
      if mod x modulo = k then 1 else 0
    else 0

  let rec count_interesting_prefixes_aux
      (nums: list int) (modulo: int) (k: int) (running_count: int) : int
    variant { nums }
  =
    match nums with
    | Nil -> 0
    | Cons x xs ->
        let next_count =
          running_count + interesting_element_indicator x modulo k in
        (if 0 < modulo then
           if mod next_count modulo = k then 1 else 0
         else 0) +
        count_interesting_prefixes_aux xs modulo k next_count
    end

  let count_interesting_prefixes
      (nums: list int) (modulo: int) (k: int) : int =
    count_interesting_prefixes_aux nums modulo k 0

  let rec count_interesting_subarrays
      (nums: list int) (modulo: int) (k: int) : int
    variant { nums }
  =
    match nums with
    | Nil -> 0
    | Cons _ xs ->
        count_interesting_prefixes nums modulo k +
        count_interesting_subarrays xs modulo k
    end

  let count_of_interesting_subarrays_list
      (nums: list int) (modulo: int) (k: int) : int =
    count_interesting_subarrays nums modulo k

  let test_000 () : bool =
    let nums = Cons 3 (Cons 2 (Cons 4 Nil)) in
    let r = count_of_interesting_subarrays_list nums 2 1 in
    r = 3

  let test_001 () : bool =
    let nums = Cons 8 (Cons 12 (Cons 16 (Cons 20 (Cons 24 Nil)))) in
    let r = count_of_interesting_subarrays_list nums 4 0 in
    r = 2

  let test_002 () : bool =
    let nums = Cons 7 (Cons 7 (Cons 7 (Cons 7 (Cons 7 (Cons 7 (Cons 7 Nil)))))) in
    let r = count_of_interesting_subarrays_list nums 7 0 in
