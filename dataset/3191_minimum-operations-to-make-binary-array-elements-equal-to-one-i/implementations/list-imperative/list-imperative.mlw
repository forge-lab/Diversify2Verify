    let r = minimum_operations_to_make_binary_array_elements_equal_to_one_i_list nums in
    r = 0

  let test_006 () : bool =
    let nums = Cons 1 (Cons 0 (Cons 0 (Cons 1 (Cons 0 (Cons 0 Nil))))) in
    let r = minimum_operations_to_make_binary_array_elements_equal_to_one_i_list nums in
    r = 2

  let test_007 () : bool =
    let nums = Cons 0 (Cons 1 (Cons 1 (Cons 1 Nil))) in
    let r = minimum_operations_to_make_binary_array_elements_equal_to_one_i_list nums in
    r = -1

  let test_008 () : bool =
    let nums = Cons 0 (Cons 0 (Cons 0 Nil)) in
    let r = minimum_operations_to_make_binary_array_elements_equal_to_one_i_list nums in
    r = 1

  let test_009 () : bool =
    let nums = Cons 1 (Cons 0 (Cons 1 (Cons 0 (Cons 1 (Cons 0 Nil))))) in
    let r = minimum_operations_to_make_binary_array_elements_equal_to_one_i_list nums in
    r = 3

  let test_010 () : bool =
    let nums = Cons 1 (Cons 0 (Cons 0 (Cons 1 (Cons 0 (Cons 0 (Cons 1 (Cons 1 (Cons 1 Nil)))))))) in
    let r = minimum_operations_to_make_binary_array_elements_equal_to_one_i_list nums in
    r = 2

  let test_011 () : bool =
    let nums = Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 Nil)))))) in
    let r = minimum_operations_to_make_binary_array_elements_equal_to_one_i_list nums in
    r = -1

  let test_012 () : bool =
    let nums = Cons 0 (Cons 1 (Cons 1 (Cons 1 (Cons 0 (Cons 0 Nil))))) in
    let r = minimum_operations_to_make_binary_array_elements_equal_to_one_i_list nums in
    r = 3

  let test_013 () : bool =
    let nums = Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 Nil))))) in
    let r = minimum_operations_to_make_binary_array_elements_equal_to_one_i_list nums in
    r = 2

  let test_014 () : bool =
    let nums = Cons 1 (Cons 1 (Cons 0 (Cons 0 (Cons 0 (Cons 1 (Cons 1 Nil)))))) in
    let r = minimum_operations_to_make_binary_array_elements_equal_to_one_i_list nums in
    r = 1

  let test_015 () : bool =
    let nums = Cons 1 (Cons 1 (Cons 0 (Cons 0 (Cons 1 (Cons 1 (Cons 0 (Cons 0 (Cons 1 (Cons 1 Nil))))))))) in
