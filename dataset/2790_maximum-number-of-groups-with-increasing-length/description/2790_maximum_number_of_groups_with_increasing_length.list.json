      "raw": "val maximum_number_of_groups_with_increasing_length_list (usageLimits: list int) : int",
      "function_name": "maximum_number_of_groups_with_increasing_length_list",
      "parameters": [
        {
          "name": "usageLimits",
          "why3_type": "list int",
          "semantic_type": "int_sequence"
        }
      ],
