  let test_018 () : bool =
    let nums = init 19 [|1; 2; 3; 4; 5; 4; 3; 4; 5; 4; 3; 4; 5; 4; 3; 4; 5; 4; 3|] in
    let expected = init 3 [|6; 10; 14|] in
