  let test_015 () : bool =
    let nums = init 17 [|9; 8; 7; 6; 5; 4; 3; 2; 1; 2; 3; 4; 5; 6; 7; 8; 9|] in
    let expected = init 3 [|7; 8; 9|] in
    let r = find_all_good_indices_array nums 4 in
    arrays_equal r expected

  let test_016 () : bool =
    let nums = init 19 [|1; 3; 2; 1; 3; 2; 1; 3; 2; 1; 3; 2; 1; 3; 2; 1; 3; 2; 1|] in
    let expected = make 0 0 in
    let r = find_all_good_indices_array nums 2 in
    arrays_equal r expected

  let test_017 () : bool =
    let nums = init 17 [|100; 99; 98; 97; 96; 97; 98; 99; 100; 101; 102; 103; 104; 103; 102; 101; 100|] in
