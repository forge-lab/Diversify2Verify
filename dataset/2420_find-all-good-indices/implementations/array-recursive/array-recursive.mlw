    arrays_equal r expected

  let test_019 () : bool =
    let nums = init 16 [|10; 9; 8; 7; 6; 5; 6; 7; 8; 9; 10; 9; 8; 7; 6; 5|] in
    let expected = init 1 [|5|] in
    let r = find_all_good_indices_array nums 5 in
    arrays_equal r expected

  let run_tests () : bool =
    if test_000 () then
    if test_001 () then
    if test_002 () then
    if test_003 () then
    if test_004 () then
    if test_005 () then
    if test_006 () then
    if test_007 () then
    if test_008 () then
    if test_009 () then
    if test_010 () then
    if test_011 () then
    if test_012 () then
    if test_013 () then
    if test_014 () then
    if test_015 () then
    if test_016 () then
    if test_017 () then
    if test_018 () then
    if test_019 () then
      true
    else false
    else false
    else false
    else false
    else false
