    arrays_equal r expected

  let test_013 () : bool =
    let nums = init 24 [|1; 2; 2; 2; 3; 3; 3; 4; 4; 4; 5; 5; 5; 4; 4; 4; 3; 3; 3; 2; 2; 2; 1; 1|] in
    let expected = init 4 [|4; 7; 15; 18|] in
    let r = find_all_good_indices_array nums 3 in
    arrays_equal r expected

  let test_014 () : bool =
    let nums = init 13 [|8; 8; 8; 8; 8; 8; 8; 8; 8; 8; 8; 8; 8|] in
    let expected = init 7 [|3; 4; 5; 6; 7; 8; 9|] in
