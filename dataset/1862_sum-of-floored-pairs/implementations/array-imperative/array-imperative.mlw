  let run_tests () : bool =
    if test_002 () then
    if test_003 () then
    if test_009 () then
    if test_004 () then
    if test_006 () then
    if test_008 () then
    if test_035 () then
    if test_000 () then
    if test_001 () then
    if test_007 () then
    if test_013 () then
    if test_017 () then
    if test_024 () then
    if test_025 () then
    if test_027 () then
    if test_036 () then
    if test_037 () then
    if test_038 () then
    if test_043 () then
    if test_044 () then
      true
    else false
    else false
    else false
