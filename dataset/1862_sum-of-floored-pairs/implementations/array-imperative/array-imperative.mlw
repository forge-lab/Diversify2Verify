module SumOfFlooredPairs_Array_Imperative

  use int.Int
  use int.EuclideanDivision
  use array.Array
  use array.Init
  use ref.Ref

  predicate valid_problem_values (nums: array int) =
    forall i: int. 0 <= i < length nums -> 1 <= nums[i] <= 100000

  predicate valid_problem_input (nums: array int) =
    1 <= length nums <= 100000 /\
    valid_problem_values nums

  let sum_of_floored_pairs_array (nums: array int) : int
    requires { valid_problem_input nums }
  =
    let total = ref 0 in
    for i = 0 to length nums - 1 do
      for j = 0 to length nums - 1 do
        total := mod (!total + div nums[i] nums[j]) 1000000007
      done
    done;
    !total

  let test_002 () : bool =
    let nums = init 3 [|2; 5; 9|] in
    let r = sum_of_floored_pairs_array nums in
    r = 10

  let test_003 () : bool =
    let nums = init 3 [|100000; 1; 100000|] in
    let r = sum_of_floored_pairs_array nums in
    r = 200005

  let test_009 () : bool =
    let nums = init 3 [|100000; 100000; 100000|] in
    let r = sum_of_floored_pairs_array nums in
    r = 9

  let test_004 () : bool =
    let nums = init 5 [|100000; 50000; 25000; 12500; 6250|] in
    let r = sum_of_floored_pairs_array nums in
    r = 57

  let test_006 () : bool =
    let nums = init 5 [|10; 20; 30; 40; 50|] in
    let r = sum_of_floored_pairs_array nums in
    r = 27

  let test_008 () : bool =
    let nums = init 5 [|1; 2; 3; 4; 5|] in
    let r = sum_of_floored_pairs_array nums in
    r = 27

  let test_035 () : bool =
