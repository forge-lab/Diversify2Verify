module MaximumNumberOfUpgradableServers_Array_Recursive_Implementation

  use int.Int
  use int.EuclideanDivision
  use array.Array
  use array.Init

  let max_upgradable_for_center
    (count_i: int) (upgrade_i: int) (sell_i: int) (money_i: int) : int =
    let affordable = div (money_i + count_i * sell_i) (upgrade_i + sell_i) in
    if affordable < 0 then
      0
    else if affordable <= count_i then
      affordable
    else
      count_i

  let rec fill_answer
    (count: array int) (upgrade: array int) (sell: array int)
    (money: array int) (answer: array int) (i: int) : unit
    variant { length count - i }
  =
    if i >= length count then
      ()
    else begin
      answer[i] <- max_upgradable_for_center count[i] upgrade[i] sell[i] money[i];
      fill_answer count upgrade sell money answer (i + 1)
    end

  let maximum_number_of_upgradable_servers_array
    (count: array int) (upgrade: array int) (sell: array int) (money: array int)
    : array int =
    let answer = make (length count) 0 in
    fill_answer count upgrade sell money answer 0;
    answer

  let rec array_eq_from (a: array int) (b: array int) (i: int) : bool
    variant { length a - i }
  =
    if i >= length a then
      true
    else if a[i] = b[i] then
      array_eq_from a b (i + 1)
    else
      false

  let array_eq (a: array int) (b: array int) : bool =
    if length a <> length b then
      false
    else
      array_eq_from a b 0

  let check_case
    (count: array int) (upgrade: array int) (sell: array int)
    (money: array int) (expected: array int) : bool =
    let r = maximum_number_of_upgradable_servers_array count upgrade sell money in
    array_eq r expected

  let test_000 () : bool =
    let count = init 1 [|100000|] in
    let upgrade = init 1 [|100000|] in
    let sell = init 1 [|100000|] in
    let money = init 1 [|1000000000|] in
    let expected = init 1 [|55000|] in
    check_case count upgrade sell money expected

