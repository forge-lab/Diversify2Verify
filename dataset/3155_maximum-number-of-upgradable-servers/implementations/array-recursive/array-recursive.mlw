    let count = init 3 [|10; 20; 30|] in
    let upgrade = init 3 [|5; 4; 3|] in
    let sell = init 3 [|1; 2; 3|] in
    let money = init 3 [|50; 100; 150|] in
    let expected = init 3 [|10; 20; 30|] in
    check_case count upgrade sell money expected

