  let test_017 () : bool =
    let nums = Cons 1 (Cons 1 (Cons 1 (Cons 2 (Cons 2 (Cons 2 (Cons 3 (Cons 3 (Cons 3 (Cons 4 (Cons 4 (Cons 4 (Cons 5 (Cons 5 (Cons 5 (Cons 6 (Cons 6 (Cons 6 (Cons 7 (Cons 7 (Cons 7 (Cons 8 (Cons 8 (Cons 8 (Cons 9 (Cons 9 (Cons 9 (Cons 10 (Cons 10 (Cons 10 Nil))))))))))))))))))))))))))))) in
