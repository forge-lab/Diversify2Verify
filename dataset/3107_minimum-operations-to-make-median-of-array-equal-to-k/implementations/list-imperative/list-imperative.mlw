module MinimumOperationsToMakeMedianOfArrayEqualToK_List_Imperative

  use int.Int
  use int.EuclideanDivision
  use list.List
  use ref.Ref

  let rec insert_sorted (x: int) (xs: list int) : list int
    variant { xs }
  =
    match xs with
    | Nil -> Cons x Nil
    | Cons y ys ->
        if x <= y then Cons x xs else Cons y (insert_sorted x ys)
    end

  let rec sum_first (n: int) (xs: list int) : int
    variant { xs }
  =
    if n <= 0 then 0 else
    match xs with
    | Nil -> 0
    | Cons x ys -> x + sum_first (n - 1) ys
    end

  let minimum_operations_to_make_median_of_array_equal_to_k_list
    (nums: list int) (k: int) : int
  =
    let below_costs = ref (Nil: list int) in
    let above_costs = ref (Nil: list int) in
    let below_count = ref 0 in
    let above_count = ref 0 in
    let total_count = ref 0 in
    let cur = ref nums in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons x xs ->
          total_count := !total_count + 1;
          if x < k then
            (below_count := !below_count + 1;
             below_costs := insert_sorted (k - x) !below_costs)
          else if x > k then
            (above_count := !above_count + 1;
             above_costs := insert_sorted (x - k) !above_costs);
          cur := xs
      end
    done;
    let max_below = div !total_count 2 in
    let max_above = !total_count - max_below - 1 in
    let raise_needed =
      if !below_count > max_below then !below_count - max_below else 0 in
    let lower_needed =
      if !above_count > max_above then !above_count - max_above else 0 in
    sum_first raise_needed !below_costs + sum_first lower_needed !above_costs

  let test_000 () : bool =
    let nums = Cons 1 (Cons 3 (Cons 3 (Cons 3 (Cons 7 (Cons 7 (Cons 9 Nil)))))) in
    let r = minimum_operations_to_make_median_of_array_equal_to_k_list nums 3 in
    r = 0

  let test_001 () : bool =
    let nums = Cons 5 (Cons 5 (Cons 5 (Cons 5 (Cons 5 Nil)))) in
    let r = minimum_operations_to_make_median_of_array_equal_to_k_list nums 5 in
    r = 0

  let test_002 () : bool =
    let nums = Cons 1 (Cons 1000000000 (Cons 2 (Cons 999999999 (Cons 3 Nil)))) in
    let r = minimum_operations_to_make_median_of_array_equal_to_k_list nums 500000000 in
    r = 499999997

  let test_003 () : bool =
    let nums = Cons 2 (Cons 5 (Cons 6 (Cons 8 (Cons 5 Nil)))) in
    let r = minimum_operations_to_make_median_of_array_equal_to_k_list nums 7 in
    r = 3

