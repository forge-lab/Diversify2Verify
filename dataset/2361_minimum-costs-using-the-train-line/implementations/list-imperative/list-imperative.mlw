module MinimumCostsUsingTheTrainLine_List_Imperative

  use int.Int
  use int.MinMax
  use list.List
  use list.Length
  use ref.Ref

  let rec reverse_list_acc (remaining: list int) (acc: list int) : list int
    variant { remaining }
  =
    match remaining with
    | Nil -> acc
    | Cons x xs -> reverse_list_acc xs (Cons x acc)
    end

  let reverse_list (l: list int) : list int =
    reverse_list_acc l Nil

  let rec equal_int_lists (left: list int) (right: list int) : bool
    variant { left }
  =
    match left, right with
    | Nil, Nil -> true
    | Cons x xs, Cons y ys -> x = y && equal_int_lists xs ys
    | _, _ -> false
    end

  let minimum_costs_using_the_train_line_list
      (regular: list int) (express: list int) (expressCost: int) : list int
    requires { length regular = length express }
  =
    let regular_so_far = ref 0 in
    let express_so_far = ref expressCost in
    let regular_cur = ref regular in
    let express_cur = ref express in
    let result_rev = ref Nil in
    while (match !regular_cur, !express_cur with Cons _ _, Cons _ _ -> true | _, _ -> false end) do
      match !regular_cur, !express_cur with
      | Cons r rs, Cons e es ->
          let next_regular = min !regular_so_far !express_so_far + r in
          let next_express = min (!regular_so_far + expressCost) !express_so_far + e in
          let best = min next_regular next_express in
          result_rev := Cons best !result_rev;
          regular_so_far := next_regular;
          express_so_far := next_express;
          regular_cur := rs;
          express_cur := es
      | _, _ -> ()
      end
    done;
    reverse_list !result_rev

  let check_case
      (regular: list int) (express: list int) (expressCost: int) (expected: list int) : bool =
    let r = minimum_costs_using_the_train_line_list regular express expressCost in
    equal_int_lists r expected

  let test_000 () : bool =
    let regular = Cons 1 (Cons 1 (Cons 1 (Cons 1 Nil))) in
    let express = Cons 1 (Cons 1 (Cons 1 (Cons 1 Nil))) in
    let expected = Cons 1 (Cons 2 (Cons 3 (Cons 4 Nil))) in
    check_case regular express 1 expected

