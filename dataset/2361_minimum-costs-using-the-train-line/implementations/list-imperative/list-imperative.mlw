    let regular = Cons 10 (Cons 20 (Cons 30 Nil)) in
    let express = Cons 5 (Cons 15 (Cons 25 Nil)) in
    let expected = Cons 7 (Cons 22 (Cons 47 Nil)) in
    check_case regular express 2 expected

