module FindAllKDistantIndicesInAnArray_List_Imperative

  use int.Int
  use int.Abs
  use list.List
  use ref.Ref

  let reverse_list (xs: list int) : list int =
    let acc = ref Nil in
    let cur = ref xs in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons x rest ->
          acc := Cons x !acc;
          cur := rest
      end
    done;
    !acc

  let same_list (xs: list int) (ys: list int) : bool =
    let left = ref xs in
    let right = ref ys in
    let ok = ref true in
    while (match !left, !right with
           | Cons _ _, Cons _ _ -> !ok
           | _, _ -> false
           end) do
      match !left, !right with
      | Cons x xs1, Cons y ys1 ->
          if x <> y then ok := false;
          left := xs1;
          right := ys1
      | _, _ -> ()
      end
    done;
    if not !ok then false else
    match !left, !right with
    | Nil, Nil -> true
    | _, _ -> false
    end

  let has_close_position (positions: list int) (idx: int) (k: int) : bool =
    let found = ref false in
    let cur = ref positions in
    while (match !cur with Nil -> false | Cons _ _ -> not !found end) do
      match !cur with
      | Nil -> ()
      | Cons pos rest ->
          if abs (idx - pos) <= k then found := true;
          cur := rest
      end
    done;
    !found

  let find_all_k_distant_indices_in_an_array_list
    (nums: list int) (key: int) (k: int) : list int =
    let rev_key_positions = ref Nil in
    let cur = ref nums in
    let idx = ref 0 in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons x rest ->
          if x = key then rev_key_positions := Cons !idx !rev_key_positions;
          cur := rest;
          idx := !idx + 1
      end
    done;
    let key_positions = reverse_list !rev_key_positions in
    let rev_result = ref Nil in
    let out_cur = ref nums in
    let out_idx = ref 0 in
    while (match !out_cur with Nil -> false | Cons _ _ -> true end) do
      match !out_cur with
      | Nil -> ()
      | Cons _ rest ->
          if has_close_position key_positions !out_idx k then
            rev_result := Cons !out_idx !rev_result;
          out_cur := rest;
          out_idx := !out_idx + 1
      end
    done;
    reverse_list !rev_result

  let test_000 () : bool =
    let nums = Cons 5 (Cons 1 (Cons 4 (Cons 1 (Cons 5 Nil)))) in
    let expected = Cons 0 (Cons 1 (Cons 2 (Cons 3 (Cons 4 Nil)))) in
    let r = find_all_k_distant_indices_in_an_array_list nums 5 2 in
    same_list r expected

  let test_001 () : bool =
    let nums = Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 Nil))))) in
    let expected = Cons 0 (Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 Nil))))) in
    let r = find_all_k_distant_indices_in_an_array_list nums 1 3 in
    same_list r expected

