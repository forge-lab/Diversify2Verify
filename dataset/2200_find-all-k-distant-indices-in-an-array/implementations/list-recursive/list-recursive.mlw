  let test_022 () : bool =
    let nums =
      Cons 1
        (Cons 3
          (Cons 5
            (Cons 7
              (Cons 9 (Cons 11 (Cons 13 (Cons 15 (Cons 17 (Cons 19 Nil))))))))) in
    let expected = range 1 9 in
    let r = find_all_k_distant_indices_in_an_array_list nums 11 4 in
    equal_int_list r expected

  let run_tests () : bool =
