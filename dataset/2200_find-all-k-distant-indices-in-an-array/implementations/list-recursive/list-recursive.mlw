module FindAllKDistantIndicesInAnArray_List_Recursive_Implementation

  use int.Int
  use list.List
  use list.Length

  let rec nth_or_zero (nums: list int) (i: int) : int
    variant { nums }
  =
    match nums with
    | Nil -> 0
    | Cons x xs ->
        if i = 0 then x else nth_or_zero xs (i - 1)
    end

  let within_distance (i: int) (j: int) (k: int) : bool =
    j <= i + k && i <= j + k

  let rec exists_key_near_from
    (nums: list int) (key: int) (k: int) (i: int) (j: int) : bool
    variant { length nums - j }
  =
    if j >= length nums then false else
    if within_distance i j k && nth_or_zero nums j = key then true
    else exists_key_near_from nums key k i (j + 1)

  let rec collect_indices
    (nums: list int) (key: int) (k: int) (i: int) (n: int) : list int
    variant { n - i }
  =
    if i >= n then Nil else
    if exists_key_near_from nums key k i 0 then
      Cons i (collect_indices nums key k (i + 1) n)
    else
      collect_indices nums key k (i + 1) n

  let find_all_k_distant_indices_in_an_array_list
    (nums: list int) (key: int) (k: int) : list int
  =
    collect_indices nums key k 0 (length nums)

  let rec range (lo: int) (hi: int) : list int
    variant { hi - lo }
  =
    if lo > hi then Nil else Cons lo (range (lo + 1) hi)

  let rec append (xs: list int) (ys: list int) : list int
    variant { xs }
  =
    match xs with
    | Nil -> ys
    | Cons x xt -> Cons x (append xt ys)
    end

  let rec repeat (n: int) (x: int) : list int
    variant { n }
  =
    if n <= 0 then Nil else Cons x (repeat (n - 1) x)

  let rec equal_int_list (xs: list int) (ys: list int) : bool
    variant { xs }
  =
    match xs with
    | Nil ->
        match ys with
        | Nil -> true
        | Cons _ _ -> false
        end
    | Cons x xt ->
        match ys with
        | Nil -> false
        | Cons y yt ->
            if x = y then equal_int_list xt yt else false
        end
    end

  let test_000 () : bool =
    let nums = Cons 5 (Cons 1 (Cons 4 (Cons 1 (Cons 5 Nil)))) in
    let expected = range 0 4 in
    let r = find_all_k_distant_indices_in_an_array_list nums 5 2 in
    equal_int_list r expected

  let test_001 () : bool =
    let nums = Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 Nil))))) in
    let expected = range 0 5 in
    let r = find_all_k_distant_indices_in_an_array_list nums 1 3 in
    equal_int_list r expected

  let test_003 () : bool =
    let nums = Cons 1 (Cons 3 (Cons 5 (Cons 7 (Cons 9 Nil)))) in
    let expected = range 0 3 in
    let r = find_all_k_distant_indices_in_an_array_list nums 3 2 in
    equal_int_list r expected

  let test_006 () : bool =
