  let test_015 () : bool =
    let nums = Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Nil)))))))))) in
    let r = split_array_largest_sum_list nums 5 in
    r = 0

  let test_016 () : bool =
    let nums = Cons 1000000 (Nil) in
    let r = split_array_largest_sum_list nums 1 in
    r = 1000000

  let test_017 () : bool =
    let nums = Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Nil)))))))))))))))))))) in
    let r = split_array_largest_sum_list nums 5 in
    r = 4

  let test_018 () : bool =
    let nums = Cons 10 (Cons 20 (Cons 30 (Cons 40 (Cons 50 (Cons 60 (Cons 70 (Cons 80 (Cons 90 (Cons 100 (Nil)))))))))) in
    let r = split_array_largest_sum_list nums 5 in
    r = 150

  let test_019 () : bool =
    let nums = Cons 3 (Cons 2 (Cons 5 (Cons 7 (Cons 1 (Cons 10 (Cons 4 (Cons 2 (Cons 8 (Cons 6 (Cons 3 (Nil))))))))))) in
    let r = split_array_largest_sum_list nums 4 in
    r = 17

