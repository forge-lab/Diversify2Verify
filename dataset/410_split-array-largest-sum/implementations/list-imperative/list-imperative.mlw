module SplitArrayLargestSum_List_Imperative_Implementation

  use int.Int
  use int.EuclideanDivision
  use list.List
  use ref.Ref

  let sum_list (nums: list int) : int =
    let total = ref 0 in
    let cur = ref nums in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons x xs ->
          total := !total + x;
          cur := xs
      end
    done;
    !total

  let max_list (nums: list int) : int =
    match nums with
    | Nil -> 0
    | Cons x xs ->
        let current = ref x in
        let cur = ref xs in
        while (match !cur with Nil -> false | Cons _ _ -> true end) do
          match !cur with
          | Nil -> ()
          | Cons y ys ->
              if y > !current then current := y;
              cur := ys
          end
        done;
        !current
    end

  let segments_needed (nums: list int) (bound: int) : int =
    match nums with
    | Nil -> 0
    | Cons x xs ->
        let segments = ref 1 in
        let current_sum = ref x in
        let cur = ref xs in
        while (match !cur with Nil -> false | Cons _ _ -> true end) do
          match !cur with
          | Nil -> ()
          | Cons y ys ->
              if !current_sum + y <= bound then
                current_sum := !current_sum + y
              else begin
                segments := !segments + 1;
                current_sum := y
              end;
              cur := ys
          end
        done;
        !segments
    end

  let can_split_with_bound (nums: list int) (k: int) (bound: int) : bool =
    max_list nums <= bound && segments_needed nums bound <= k

  let split_array_largest_sum_list (nums: list int) (k: int) : int =
    if k <= 0 then
      0
    else
      match nums with
      | Nil -> 0
      | Cons _ _ ->
          let low = ref (max_list nums) in
          let high = ref (sum_list nums) in
          while !low < !high do
            let mid = !low + div (!high - !low) 2 in
            if can_split_with_bound nums k mid then
              high := mid
            else
              low := mid + 1
          done;
          !low
      end

  let test_000 () : bool =
    let nums = Cons 7 (Cons 2 (Cons 5 (Cons 10 (Cons 8 (Nil))))) in
    let r = split_array_largest_sum_list nums 2 in
    r = 18

  let test_001 () : bool =
    let nums = Cons 5 (Cons 5 (Cons 5 (Cons 5 (Cons 5 (Nil))))) in
    let r = split_array_largest_sum_list nums 5 in
    r = 5

  let test_002 () : bool =
    let nums = Cons 10 (Cons 10 (Cons 10 (Cons 10 (Nil)))) in
    let r = split_array_largest_sum_list nums 2 in
    r = 20

  let test_003 () : bool =
    let nums = Cons 10 (Cons 5 (Cons 13 (Cons 4 (Cons 8 (Cons 4 (Cons 5 (Cons 11 (Cons 14 (Cons 9 (Cons 15 (Nil))))))))))) in
    let r = split_array_largest_sum_list nums 6 in
    r = 23

