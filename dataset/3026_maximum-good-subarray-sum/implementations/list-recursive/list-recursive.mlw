module MaximumGoodSubarraySum_List_Recursive_Implementation

  use int.Int
  use int.Abs
  use list.List

  type maybe_int =
    | NoResult
    | Result int

  let better (a: maybe_int) (b: maybe_int) : maybe_int =
    match a with
    | NoResult -> b
    | Result x ->
        match b with
        | NoResult -> a
        | Result y -> if x >= y then a else b
        end
    end

  let rec best_with_first (first: int) (acc: int) (rest: list int) (k: int) : maybe_int
    variant { rest }
  =
    match rest with
    | Nil -> NoResult
    | Cons x xs ->
        let next_sum = acc + x in
        let current =
          if abs (first - x) = k then Result next_sum else NoResult
        in
        better current (best_with_first first next_sum xs k)
    end

  let rec best_over_starts (nums: list int) (k: int) : maybe_int
    variant { nums }
  =
    match nums with
    | Nil -> NoResult
    | Cons _ Nil -> NoResult
    | Cons x xs ->
        better (best_with_first x x xs k) (best_over_starts xs k)
    end

  let maximum_good_subarray_sum_list (nums: list int) (k: int) : int =
    match best_over_starts nums k with
    | NoResult -> 0
    | Result best -> best
    end

  let test_000 () : bool =
    let nums = Cons 1000000000 (Cons (-1000000000) Nil) in
    let r = maximum_good_subarray_sum_list nums 2000000000 in
    r = 0

  let test_001 () : bool =
    let nums = Cons (-1) (Cons 3 (Cons 2 (Cons 4 (Cons 5 Nil)))) in
    let r = maximum_good_subarray_sum_list nums 3 in
    r = 11

  let test_002 () : bool =
    let nums = Cons 10 (Cons 20 (Cons 30 (Cons 40 (Cons 50 Nil)))) in
    let r = maximum_good_subarray_sum_list nums 20 in
    r = 120

  let test_005 () : bool =
    let nums = Cons (-1000000000) (Cons 1000000000 (Cons (-1000000000) (Cons 1000000000 Nil))) in
    let r = maximum_good_subarray_sum_list nums 2000000000 in
