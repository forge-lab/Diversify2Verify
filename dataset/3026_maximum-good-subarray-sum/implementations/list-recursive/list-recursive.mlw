  let test_023 () : bool =
    let nums = Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 (Cons 6 (Cons 7 (Cons 8 (Cons 9 (Cons 10 (Cons 11 (Cons 12 (Cons 13 (Cons 14 (Cons 15 (Cons 16 (Cons 17 (Cons 18 (Cons 19 (Cons 20 (Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 Nil)))))))))))))))))))))))) in
    let r = maximum_good_subarray_sum_list nums 19 in
    r = 210

  let test_024 () : bool =
    let nums = Cons (-1) (Cons 0 (Cons 1 (Cons (-2) (Cons 2 (Cons (-3) (Cons 3 (Cons (-4) (Cons 4 (Cons (-5) (Cons 5 Nil)))))))))) in
    let r = maximum_good_subarray_sum_list nums 5 in
    r = 1

