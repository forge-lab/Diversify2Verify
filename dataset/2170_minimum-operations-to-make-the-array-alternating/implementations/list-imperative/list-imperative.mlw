            (Cons 2
              (Cons 1
                (Cons 2
                  (Cons 1
                    (Cons 2
                      (Cons 1 Nil)))))))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 0

  let test_006 () : bool =
    let nums = Cons 1 (Cons 3 (Cons 2 (Cons 3 (Cons 2 (Cons 3 Nil))))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 1

  let test_007 () : bool =
    let nums = Cons 100000 (Cons 1 (Cons 100000 (Cons 1 (Cons 100000 (Cons 1 Nil))))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 0

  let test_008 () : bool =
    let nums = Cons 3 (Cons 1 (Cons 3 (Cons 2 (Cons 4 (Cons 3 Nil))))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 3

  let test_009 () : bool =
    let nums = Cons 1 (Cons 1 (Cons 2 (Cons 2 (Cons 3 (Cons 3 (Cons 4 (Cons 4 (Cons 5 (Cons 5 (Cons 6 (Cons 6 (Cons 7 (Cons 7 (Cons 8 (Cons 8 (Cons 9 (Cons 9 (Cons 10 (Cons 10 (Nil)))))))))))))))))))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 18

  let test_010 () : bool =
    let nums = Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 Nil)))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 3

  let test_011 () : bool =
    let nums =
      Cons 1
        (Cons 1
          (Cons 1
            (Cons 1
              (Cons 1
                (Cons 1
                  (Cons 1 Nil)))))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 3

  let test_012 () : bool =
    let nums = Cons 2 (Cons 1 (Cons 2 (Cons 1 (Cons 2 (Cons 1 (Cons 2 Nil)))))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 0

  let test_013 () : bool =
    let nums = Cons 2 (Cons 3 (Cons 2 (Cons 3 (Cons 2 (Cons 3 Nil))))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
