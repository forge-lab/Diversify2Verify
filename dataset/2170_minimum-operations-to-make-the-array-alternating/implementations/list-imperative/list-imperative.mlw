  let test_014 () : bool =
    let nums =
      Cons 1
        (Cons 2
          (Cons 3
            (Cons 4
              (Cons 5
                (Cons 6
                  (Cons 7
                    (Cons 8
                      (Cons 9 Nil)))))))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 7

  let test_015 () : bool =
    let nums = Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 Nil)))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 2

  let test_016 () : bool =
    let nums = Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 (Cons 6 Nil))))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
