      Cons 1
        (Cons 3
          (Cons 1
            (Cons 3
              (Cons 2
                (Cons 3
                  (Cons 1
                    (Cons 3
                      (Cons 1
                        (Cons 3 Nil))))))))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 1

  let test_004 () : bool =
    let nums = Cons 1 Nil in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 0

  let test_005 () : bool =
    let nums =
      Cons 1
        (Cons 2
