  let test_017 () : bool =
    let nums = Cons 1 (Cons 2 (Cons 2 (Cons 2 (Cons 2 Nil)))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 2

  let test_018 () : bool =
    let nums = Cons 1 (Cons 3 (Cons 1 (Cons 3 (Cons 1 (Cons 3 Nil))))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 0

  let test_019 () : bool =
    let nums = Cons 100000 (Cons 99999 (Cons 100000 (Cons 99999 (Cons 100000 Nil)))) in
    let result = minimum_operations_to_make_the_array_alternating_list nums in
    result = 0

  let run_tests () : bool =
    if test_000 () then
    if test_001 () then
    if test_002 () then
    if test_003 () then
    if test_004 () then
    if test_005 () then
    if test_006 () then
    if test_007 () then
