    arrays_equal r expected

  let test_007 () : bool =
    let nums = init 7 [|2; 4; 8; 16; 32; 64; 128|] in
    let expected = init 7 [|128; 64; 32; 16; 8; 4; 2|] in
    let r = largest_divisible_subset_array nums in
    arrays_equal r expected

  let test_008 () : bool =
    let nums = init 5 [|18; 3; 6; 2; 9|] in
    let expected = init 3 [|18; 9; 3|] in
