    let r = largest_divisible_subset_array nums in
    arrays_equal r expected

  let test_015 () : bool =
    let nums = init 4 [|10; 5; 2; 6|] in
    let expected = init 2 [|6; 2|] in
    let r = largest_divisible_subset_array nums in
    arrays_equal r expected

  let test_016 () : bool =
    let nums = init 5 [|10; 5; 3; 15; 20|] in
    let expected = init 3 [|20; 10; 5|] in
    let r = largest_divisible_subset_array nums in
    arrays_equal r expected

  let test_017 () : bool =
    let nums = init 5 [|100; 200; 400; 800; 1600|] in
    let expected = init 5 [|1600; 800; 400; 200; 100|] in
    let r = largest_divisible_subset_array nums in
    arrays_equal r expected

  let test_018 () : bool =
    let nums = init 6 [|3; 6; 9; 12; 18; 24|] in
    let expected = init 4 [|24; 12; 6; 3|] in
    let r = largest_divisible_subset_array nums in
    arrays_equal r expected

  let test_019 () : bool =
    let nums = init 6 [|7; 14; 28; 56; 112; 224|] in
    let expected = init 6 [|224; 112; 56; 28; 14; 7|] in
    let r = largest_divisible_subset_array nums in
    arrays_equal r expected

  let run_tests () : bool =
    if test_000 () then
    if test_001 () then
    if test_002 () then
    if test_003 () then
    if test_004 () then
    if test_005 () then
    if test_006 () then
    if test_007 () then
    if test_008 () then
    if test_009 () then
    if test_010 () then
    if test_011 () then
    if test_012 () then
    if test_013 () then
    if test_014 () then
    if test_015 () then
    if test_016 () then
    if test_017 () then
    if test_018 () then
    if test_019 () then
      true
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
