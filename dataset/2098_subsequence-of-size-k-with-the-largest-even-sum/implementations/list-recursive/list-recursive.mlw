  let test_019 () : bool =
    let nums = Cons 100 (Cons 99 (Cons 98 (Cons 97 (Cons 96 (Cons 95 (Cons 94 (Cons 93 (Cons 92 (Cons 91 (Cons 90 (Cons 89 (Cons 88 (Cons 87 (Cons 86 (Cons 85 (Cons 84 (Cons 83 (Cons 82 (Cons 81 (Cons 80 (Nil))))))))))))))))))))) in
    let r = subsequence_of_size_k_with_the_largest_even_sum_list nums 10 in
    r = 954

