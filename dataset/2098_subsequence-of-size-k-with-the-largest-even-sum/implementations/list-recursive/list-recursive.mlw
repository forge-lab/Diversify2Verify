  let test_018 () : bool =
    let nums = Cons 100000 (Cons 99999 (Cons 99998 (Cons 99997 (Cons 99996 (Cons 99995 (Cons 99994 (Cons 99993 (Cons 99992 (Cons 99991 (Nil)))))))))) in
    let r = subsequence_of_size_k_with_the_largest_even_sum_list nums 5 in
