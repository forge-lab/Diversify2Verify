  let test_016 () : bool =
    let nums = Cons 1 (Cons 3 (Cons 2 (Cons 4 (Cons 5 (Cons 7 (Cons 6 (Cons 8 (Cons 9 (Cons 11 (Cons 10 (Cons 12 (Cons 13 (Cons 15 (Cons 14 (Cons 16 (Cons 17 (Cons 19 (Cons 18 (Cons 20 (Nil)))))))))))))))))))) in
    let result = minimize_the_maximum_difference_of_pairs_list nums 10 in
