module MinimumCostToMakeArrayEqual_List_Imperative

  use int.Int
  use int.Abs
  use list.List
  use ref.Ref

  let weighted_cost_to (nums: list int) (costs: list int) (target: int) : int =
    let total = ref 0 in
    let ns = ref nums in
    let cs = ref costs in
    while
      (match !ns with
       | Nil -> false
       | Cons _ _ ->
           match !cs with
           | Nil -> false
           | Cons _ _ -> true
           end
       end)
    do
      match !ns with
      | Nil -> ()
      | Cons n ns' ->
          match !cs with
          | Nil -> ()
          | Cons c cs' ->
              total := !total + c * abs (n - target);
              ns := ns';
              cs := cs'
          end
      end
    done;
    !total

  let minimum_cost_to_make_array_equal_list (nums: list int) (cost: list int) : int =
    match nums with
    | Nil -> 0
    | Cons first rest ->
        let best = ref (weighted_cost_to nums cost first) in
        let cur = ref rest in
        while (match !cur with Nil -> false | Cons _ _ -> true end) do
          match !cur with
          | Nil -> ()
          | Cons target remaining ->
              let current = weighted_cost_to nums cost target in
              if current < !best then best := current;
              cur := remaining
          end
        done;
        !best
    end

  let test_000 () : bool =
    let nums = Cons 6 (Cons 1 (Cons 3 (Cons 9 (Cons 3 Nil)))) in
    let cost = Cons 2 (Cons 1 (Cons 2 (Cons 1 (Cons 2 Nil)))) in
    let r = minimum_cost_to_make_array_equal_list nums cost in
    r = 14

  let test_001 () : bool =
    let nums = Cons 1 (Cons 3 (Cons 5 (Cons 2 Nil))) in
    let cost = Cons 2 (Cons 3 (Cons 1 (Cons 14 Nil))) in
    let r = minimum_cost_to_make_array_equal_list nums cost in
    r = 8

  let test_002 () : bool =
    let nums = Cons 2 (Cons 2 (Cons 2 (Cons 2 (Cons 2 Nil)))) in
    let cost = Cons 4 (Cons 2 (Cons 8 (Cons 1 (Cons 3 Nil)))) in
    let r = minimum_cost_to_make_array_equal_list nums cost in
    r = 0

