    let cost = Cons 1000 (Cons 2000 (Cons 3000 (Cons 4000 (Cons 5000 (Cons 6000 (Cons 7000 (Cons 8000 (Cons 9000 (Cons 10000 (Cons 11000 (Cons 12000 (Cons 13000 (Cons 14000 (Cons 15000 (Cons 16000 (Cons 17000 (Cons 18000 (Cons 19000 (Cons 20000 (Nil)))))))))))))))))))) in
