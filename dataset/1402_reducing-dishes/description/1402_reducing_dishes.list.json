      "raw": "val reducing_dishes_list (satisfaction: list int) : int",
      "function_name": "reducing_dishes_list",
      "parameters": [
        {
          "name": "satisfaction",
          "why3_type": "list int",
          "semantic_type": "int_sequence"
        }
      ],
      "return": {
