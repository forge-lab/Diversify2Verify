module TwoSumLessThanK_List_Imperative_Implementation

  use int.Int
  use list.List
  use ref.Ref

  let two_sum_less_than_k_list (nums: list int) (k: int) : int =
    let best = ref (-1) in
    let outer = ref nums in
    while (match !outer with Nil -> false | Cons _ _ -> true end) do
      match !outer with
      | Nil -> ()
      | Cons x xs ->
          let inner = ref xs in
          while (match !inner with Nil -> false | Cons _ _ -> true end) do
            match !inner with
            | Nil -> ()
            | Cons y ys ->
                let candidate = x + y in
                if candidate < k && candidate > !best then best := candidate;
                inner := ys
            end
          done;
          outer := xs
      end
    done;
    !best

  let test_case_000 () : bool =
    let nums = Cons 500 (Cons 500 (Cons 500 (Cons 500 Nil))) in
    let r = two_sum_less_than_k_list nums 1000 in
    r = -1

  let test_case_001 () : bool =
    let nums = Cons 5 (Cons 15 (Cons 25 (Cons 35 Nil))) in
    let r = two_sum_less_than_k_list nums 50 in
    r = 40

  let test_case_002 () : bool =
    let nums = Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 Nil)))) in
    let r = two_sum_less_than_k_list nums 8 in
    r = 7

