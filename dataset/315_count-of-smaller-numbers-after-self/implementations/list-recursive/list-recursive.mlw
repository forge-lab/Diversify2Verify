module CountOfSmallerNumbersAfterSelf_List_Recursive_Implementation

  use int.Int
  use list.List

  let rec count_smaller_than (x: int) (l: list int) : int
    variant { l }
  =
    match l with
    | Nil -> 0
    | Cons y ys ->
        (if y < x then 1 else 0) + count_smaller_than x ys
    end

  let rec count_of_smaller_numbers_after_self_list (nums: list int) : list int
    variant { nums }
  =
    match nums with
    | Nil -> Nil
    | Cons x xs ->
        Cons (count_smaller_than x xs) (count_of_smaller_numbers_after_self_list xs)
    end

  let rec eq_list_int (xs: list int) (ys: list int) : bool
    variant { xs }
  =
    match xs with
    | Nil ->
        match ys with
        | Nil -> true
        | Cons _ _ -> false
        end
    | Cons x xt ->
        match ys with
        | Nil -> false
        | Cons y yt ->
            if x = y then eq_list_int xt yt else false
        end
    end

  let test_000 () : bool =
    let nums = Cons (-1) (Cons (-1) Nil) in
    let expected = Cons 0 (Cons 0 Nil) in
    let result = count_of_smaller_numbers_after_self_list nums in
    eq_list_int result expected

  let test_001 () : bool =
    let nums = Cons 10000 (Cons (-10000) (Cons 5000 (Cons 0 (Cons 5000 Nil)))) in
    let expected = Cons 4 (Cons 0 (Cons 1 (Cons 0 (Cons 0 Nil)))) in
    let result = count_of_smaller_numbers_after_self_list nums in
    eq_list_int result expected

  let test_002 () : bool =
    let nums = Cons 4 (Cons 5 (Cons 6 (Cons 7 (Cons 8 (Cons 9 (Cons 10 Nil)))))) in
    let expected = Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 Nil)))))) in
    let result = count_of_smaller_numbers_after_self_list nums in
    eq_list_int result expected

