  let test_016 () : bool =
    let nums =
      Cons 1
        (Cons 3
          (Cons 5
            (Cons 7 (Cons 9 (Cons 11 (Cons 13 (Cons 15 (Cons 17 (Cons 19 Nil)))))))))
    in
