module CountOfSmallerNumbersAfterSelf_List_Imperative

  use int.Int
  use list.List
  use ref.Ref

  let reverse_list (l: list int) : list int =
    let cur = ref l in
    let acc = ref Nil in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons x xs ->
          acc := Cons x !acc;
          cur := xs
      end
    done;
    !acc

  let count_smaller_than_tail (x: int) (l: list int) : int =
    let count = ref 0 in
    let cur = ref l in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons y ys ->
          if y < x then count := !count + 1;
          cur := ys
      end
    done;
    !count

  let rec function same_list (xs: list int) (ys: list int) : bool
    variant { xs }
  =
    match xs, ys with
    | Nil, Nil -> true
    | Cons x xs1, Cons y ys1 -> x = y && same_list xs1 ys1
    | _, _ -> false
    end

  let count_of_smaller_numbers_after_self_list (nums: list int) : list int =
    let cur = ref nums in
    let rev_result = ref Nil in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons x xs ->
          let count = count_smaller_than_tail x xs in
          rev_result := Cons count !rev_result;
          cur := xs
      end
    done;
    reverse_list !rev_result

  let test_000 () : bool =
    let nums = Cons (-1) (Cons (-1) Nil) in
    let expected = Cons 0 (Cons 0 Nil) in
    let r = count_of_smaller_numbers_after_self_list nums in
    same_list r expected

  let test_001 () : bool =
    let nums =
      Cons 10000 (Cons (-10000) (Cons 5000 (Cons 0 (Cons 5000 Nil))))
    in
    let expected = Cons 4 (Cons 0 (Cons 1 (Cons 0 (Cons 0 Nil)))) in
    let r = count_of_smaller_numbers_after_self_list nums in
    same_list r expected

  let test_002 () : bool =
    let nums = Cons 4 (Cons 5 (Cons 6 (Cons 7 (Cons 8 (Cons 9 (Cons 10 Nil)))))) in
    let expected = Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 Nil)))))) in
    let r = count_of_smaller_numbers_after_self_list nums in
    same_list r expected

  let test_003 () : bool =
    let nums = Cons 0 (Cons 1 (Cons 0 (Cons 1 (Cons 0 (Cons 1 Nil))))) in
    let expected = Cons 0 (Cons 2 (Cons 0 (Cons 1 (Cons 0 (Cons 0 Nil))))) in
    let r = count_of_smaller_numbers_after_self_list nums in
    same_list r expected

  let test_004 () : bool =
    let nums = Cons 0 (Cons (-1) (Cons 1 (Cons (-2) (Cons 2 Nil)))) in
    let expected = Cons 2 (Cons 1 (Cons 1 (Cons 0 (Cons 0 Nil)))) in
    let r = count_of_smaller_numbers_after_self_list nums in
    same_list r expected

  let test_005 () : bool =
    let nums = Cons 100 (Cons 200 (Cons 150 (Cons 100 Nil))) in
    let expected = Cons 0 (Cons 2 (Cons 1 (Cons 0 Nil))) in
    let r = count_of_smaller_numbers_after_self_list nums in
    same_list r expected

  let test_006 () : bool =
    let nums = Cons 100 (Cons 99 (Cons 98 (Cons 97 (Cons 96 Nil)))) in
    let expected = Cons 4 (Cons 3 (Cons 2 (Cons 1 (Cons 0 Nil)))) in
    let r = count_of_smaller_numbers_after_self_list nums in
