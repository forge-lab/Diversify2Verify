    let expected = Cons 3 (Cons 1 (Cons 2 (Cons 0 (Cons 2 (Cons 1 (Cons 0 (Cons 0 Nil))))))) in
    let r = count_of_smaller_numbers_after_self_list nums in
    same_list r expected

  let test_015 () : bool =
    let nums = Cons (-5) (Cons (-4) (Cons (-3) (Cons (-2) (Cons (-1) Nil)))) in
    let expected = Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 Nil)))) in
    let r = count_of_smaller_numbers_after_self_list nums in
