      Cons 10
        (Cons 9
          (Cons 8
            (Cons 7 (Cons 6 (Cons 5 (Cons 4 (Cons 3 (Cons 2 (Cons 1 Nil)))))))))
    in
    let expected =
      Cons 9
        (Cons 8
          (Cons 7
            (Cons 6 (Cons 5 (Cons 4 (Cons 3 (Cons 2 (Cons 1 (Cons 0 Nil)))))))))
    in
    let r = count_of_smaller_numbers_after_self_list nums in
    same_list r expected

  let test_011 () : bool =
