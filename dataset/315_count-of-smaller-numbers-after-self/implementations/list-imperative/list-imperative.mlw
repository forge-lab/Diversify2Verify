  let test_019 () : bool =
    let nums = Cons 5 (Cons 2 (Cons 6 (Cons 1 Nil))) in
    let expected = Cons 2 (Cons 1 (Cons 1 (Cons 0 Nil))) in
    let r = count_of_smaller_numbers_after_self_list nums in
    same_list r expected

  let run_tests () : bool =
    if test_000 () then
    if test_001 () then
    if test_002 () then
    if test_003 () then
    if test_004 () then
    if test_005 () then
    if test_006 () then
    if test_007 () then
