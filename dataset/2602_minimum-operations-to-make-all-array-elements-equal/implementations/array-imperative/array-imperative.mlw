  let test_005 () : bool =
    let nums = init 10 [|1; 2; 2; 3; 3; 3; 4; 4; 4; 4|] in
    let queries = init 3 [|2; 3; 4|] in
    let expected = init 3 [|12; 8; 10|] in
    check_case nums queries expected

  let test_006 () : bool =
    let nums = init 4 [|1; 1; 1; 1|] in
    let queries = init 1 [|1|] in
    let expected = init 1 [|0|] in
    check_case nums queries expected

