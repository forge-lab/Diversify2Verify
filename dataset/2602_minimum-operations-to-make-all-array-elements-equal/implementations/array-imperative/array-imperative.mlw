module MinimumOperationsToMakeAllArrayElementsEqual_Array_Imperative

  use int.Int
  use int.Abs
  use array.Array
  use array.Init
  use ref.Ref

  exception ArrayMismatch

  let minimum_operations_to_make_all_array_elements_equal_array
    (nums: array int) (queries: array int) : array int =
    let result = make (length queries) 0 in
    for j = 0 to length queries - 1 do
      let total = ref 0 in
      let q = queries[j] in
      for i = 0 to length nums - 1 do
        total := !total + abs (nums[i] - q)
      done;
      result[j] <- !total
    done;
    result

  let arrays_equal (a: array int) (b: array int) : bool =
    if length a <> length b then
      false
    else if length a = 0 then
      true
    else
      try
        for i = 0 to length a - 1 do
          if a[i] <> b[i] then
            raise ArrayMismatch
        done;
        true
      with ArrayMismatch ->
        false
      end

  let check_case
    (nums: array int) (queries: array int) (expected: array int) : bool =
    let r = minimum_operations_to_make_all_array_elements_equal_array nums queries in
    arrays_equal r expected

  let test_000 () : bool =
    let nums = init 1 [|1000000000|] in
    let queries = init 3 [|1000000000; 1; 999999999|] in
    let expected = init 3 [|0; 999999999; 1|] in
    check_case nums queries expected

  let test_001 () : bool =
    let nums = init 4 [|2; 9; 6; 3|] in
    let queries = init 1 [|10|] in
    let expected = init 1 [|20|] in
    check_case nums queries expected

  let test_002 () : bool =
    let nums = init 5 [|1; 1; 1; 1; 1|] in
    let queries = init 3 [|1; 2; 3|] in
    let expected = init 3 [|0; 5; 10|] in
    check_case nums queries expected

  let test_003 () : bool =
    let nums = init 3 [|100; 200; 300|] in
    let queries = init 2 [|150; 250|] in
    let expected = init 2 [|250; 250|] in
    check_case nums queries expected

  let test_004 () : bool =
    let nums = init 5 [|1; 2; 3; 4; 5|] in
