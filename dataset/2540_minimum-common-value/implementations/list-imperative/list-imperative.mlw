  let test_014 () : bool =
    let nums1 = Cons 1 (Cons 5 (Cons 9 Nil)) in
    let nums2 = Cons 3 (Cons 7 (Cons 11 Nil)) in
    check_case nums1 nums2 (-1)

  let test_015 () : bool =
    let nums1 = Cons 5 (Cons 10 (Cons 15 Nil)) in
    let nums2 = Cons 15 (Cons 20 (Cons 25 Nil)) in
