  let test_009 () : bool =
    let nums1 = Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 Nil)))) in
    let nums2 = Cons 6 (Cons 7 (Cons 8 (Cons 9 (Cons 10 Nil)))) in
    check_case nums1 nums2 (-1)

  let test_010 () : bool =
    let nums1 = Cons 1000000000 Nil in
    let nums2 = Cons 1000000000 Nil in
    check_case nums1 nums2 1000000000

  let test_011 () : bool =
    let nums1 = Cons 1 (Cons 5 (Cons 9 Nil)) in
    let nums2 = Cons 3 (Cons 6 (Cons 9 Nil)) in
    check_case nums1 nums2 9

  let test_012 () : bool =
    let nums1 = Cons 1 (Cons 5 (Cons 9 (Cons 13 (Cons 17 Nil)))) in
    let nums2 = Cons 2 (Cons 6 (Cons 10 (Cons 14 (Cons 18 Nil)))) in
    check_case nums1 nums2 (-1)

  let test_013 () : bool =
    let nums1 = Cons 1 Nil in
    let nums2 = Cons 2 Nil in
