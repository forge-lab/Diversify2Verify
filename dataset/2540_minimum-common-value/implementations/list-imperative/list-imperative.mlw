module MinimumCommonValue_List_Imperative

  use int.Int
  use list.List
  use ref.Ref

  let minimum_common_value_list (nums1: list int) (nums2: list int) : int =
    let cur1 = ref nums1 in
    let cur2 = ref nums2 in
    let result = ref (-1) in
    let searching = ref true in
    while !searching do
      match !cur1 with
      | Nil ->
          searching := false
      | Cons x xs ->
          match !cur2 with
          | Nil ->
              searching := false
          | Cons y ys ->
              if x = y then (
                result := x;
                searching := false
              ) else if x < y then
                cur1 := xs
              else
                cur2 := ys
          end
      end
    done;
    !result

  let check_case (nums1: list int) (nums2: list int) (expected: int) : bool =
    let r = minimum_common_value_list nums1 nums2 in
    r = expected

  let test_000 () : bool =
    let nums1 = Cons 1 (Cons 2 (Cons 2 (Cons 3 Nil))) in
    let nums2 = Cons 2 (Cons 2 Nil) in
    check_case nums1 nums2 2

  let test_001 () : bool =
    let nums1 = Cons 10 (Cons 20 (Cons 30 Nil)) in
    let nums2 = Cons 5 (Cons 15 (Cons 25 (Cons 35 Nil))) in
    check_case nums1 nums2 (-1)

  let test_002 () : bool =
    let nums1 = Cons 1 (Cons 1 (Cons 1 (Cons 1 Nil))) in
    let nums2 = Cons 1 (Cons 1 (Cons 1 (Cons 1 Nil))) in
    check_case nums1 nums2 1

  let test_003 () : bool =
    let nums1 = Cons 1 (Cons 3 (Cons 5 (Cons 7 Nil))) in
    let nums2 = Cons 2 (Cons 4 (Cons 6 (Cons 8 Nil))) in
    check_case nums1 nums2 (-1)

  let test_004 () : bool =
