  let test_017 () : bool =
    let nums1 = Cons 1 (Cons 2 (Cons 3 (Cons 6 Nil))) in
    let nums2 = Cons 2 (Cons 3 (Cons 4 (Cons 5 Nil))) in
    check_case nums1 nums2 2

  let test_018 () : bool =
    let nums1 = Cons 1 (Cons 10 (Cons 20 Nil)) in
    let nums2 = Cons 5 (Cons 15 (Cons 25 Nil)) in
    check_case nums1 nums2 (-1)

  let test_019 () : bool =
    let nums1 = Cons 1 Nil in
    let nums2 = Cons 1 Nil in
    check_case nums1 nums2 1

  let run_tests () : bool =
    if test_000 () then
    if test_001 () then
    if test_002 () then
    if test_003 () then
    if test_004 () then
    if test_005 () then
    if test_006 () then
    if test_007 () then
    if test_008 () then
    if test_009 () then
    if test_010 () then
    if test_011 () then
    if test_012 () then
    if test_013 () then
    if test_014 () then
    if test_015 () then
    if test_016 () then
    if test_017 () then
    if test_018 () then
    if test_019 () then
      true
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false
    else false

end
