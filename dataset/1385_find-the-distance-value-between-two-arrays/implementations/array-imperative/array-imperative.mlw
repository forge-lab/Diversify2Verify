    let arr2 = init 5 [|6; 7; 8; 9; 10|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 1 in
    r = 4

  let test_011 () : bool =
    let arr1 = init 5 [|100; 200; 300; 400; 500|] in
    let arr2 = init 10 [|50; 100; 150; 200; 250; 300; 350; 400; 450; 500|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 49 in
    r = 0

  let test_012 () : bool =
    let arr1 = init 5 [|-1000; -900; -800; -700; -600|] in
    let arr2 = init 5 [|600; 700; 800; 900; 1000|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 100 in
    r = 5

  let test_013 () : bool =
    let arr1 = init 3 [|-100; -200; -300|] in
    let arr2 = init 3 [|-50; -150; -250|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 49 in
    r = 3

  let test_014 () : bool =
    let arr1 = init 5 [|500; 500; 500; 500; 500|] in
    let arr2 = init 5 [|500; 500; 500; 500; 500|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 0 in
    r = 0

  let test_015 () : bool =
    let arr1 = init 5 [|10; 20; 30; 40; 50|] in
    let arr2 = init 5 [|1; 2; 3; 4; 5|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 5 in
    r = 4

  let test_016 () : bool =
    let arr1 = init 5 [|1; 2; 3; 4; 5|] in
    let arr2 = init 5 [|10; 20; 30; 40; 50|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 10 in
    r = 0

  let test_017 () : bool =
    let arr1 = init 5 [|1; 1; 1; 1; 1|] in
    let arr2 = init 5 [|2; 4; 6; 8; 10|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 1 in
    r = 0

  let test_018 () : bool =
    let arr1 = init 4 [|500; 1000; 1500; 2000|] in
    let arr2 = init 4 [|400; 900; 1400; 1900|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 100 in
    r = 0

  let test_019 () : bool =
    let arr1 = init 5 [|0; 100; 200; 300; 400|] in
    let arr2 = init 5 [|50; 150; 250; 350; 450|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 50 in
    r = 0

  let run_tests () : bool =
    if test_000 () then
    if test_001 () then
    if test_002 () then
    if test_003 () then
    if test_004 () then
    if test_005 () then
    if test_006 () then
    if test_007 () then
    if test_008 () then
    if test_009 () then
    if test_010 () then
    if test_011 () then
    if test_012 () then
    if test_013 () then
    if test_014 () then
    if test_015 () then
    if test_016 () then
    if test_017 () then
    if test_018 () then
    if test_019 () then
      true
    else false
    else false
    else false
    else false
    else false
