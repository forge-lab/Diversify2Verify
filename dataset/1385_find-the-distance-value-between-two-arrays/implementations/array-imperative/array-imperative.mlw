module FindTheDistanceValueBetweenTwoArrays_Array_Imperative

  use int.Int
  use int.Abs
  use array.Array
  use array.Init
  use ref.Ref

  let is_far_from_all (arr2: array int) (x: int) (d: int) : bool =
    let ok = ref true in
    let j = ref 0 in
    while !j < length arr2 do
      if abs (x - arr2[!j]) <= d then
        ok := false;
      j := !j + 1
    done;
    !ok

  let find_the_distance_value_between_two_arrays_array
      (arr1: array int) (arr2: array int) (d: int) : int =
    let count = ref 0 in
    let i = ref 0 in
    while !i < length arr1 do
      if is_far_from_all arr2 arr1[!i] d then
        count := !count + 1;
      i := !i + 1
    done;
    !count

  let test_000 () : bool =
    let arr1 = init 3 [|10; 20; 30|] in
    let arr2 = init 3 [|5; 15; 25|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 4 in
    r = 3

  let test_001 () : bool =
    let arr1 = init 2 [|-1000; 1000|] in
    let arr2 = init 2 [|-500; 500|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 499 in
    r = 2

  let test_002 () : bool =
    let arr1 = init 3 [|4; 5; 8|] in
    let arr2 = init 4 [|10; 9; 1; 8|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 2 in
    r = 2

  let test_003 () : bool =
    let arr1 = init 4 [|1; 4; 2; 3|] in
    let arr2 = init 6 [|-4; -3; 6; 10; 20; 30|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 3 in
    r = 2

  let test_004 () : bool =
    let arr1 = init 3 [|-1; -2; -3|] in
    let arr2 = init 3 [|1; 2; 3|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 2 in
    r = 2

  let test_005 () : bool =
    let arr1 = init 4 [|0; 0; 0; 0|] in
    let arr2 = init 4 [|1; 2; 3; 4|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 0 in
    r = 4

  let test_006 () : bool =
    let arr1 = init 1 [|1000|] in
    let arr2 = init 1 [|-1000|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 1999 in
    r = 1

  let test_007 () : bool =
    let arr1 = init 1 [|1|] in
    let arr2 = init 1 [|1|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 0 in
    r = 0

  let test_008 () : bool =
    let arr1 = init 4 [|2; 1; 100; 3|] in
    let arr2 = init 5 [|-5; -2; 10; -3; 7|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 6 in
    r = 1

  let test_009 () : bool =
    let arr1 = init 3 [|1; 2; 3|] in
    let arr2 = init 3 [|4; 5; 6|] in
    let r = find_the_distance_value_between_two_arrays_array arr1 arr2 0 in
    r = 3

  let test_010 () : bool =
