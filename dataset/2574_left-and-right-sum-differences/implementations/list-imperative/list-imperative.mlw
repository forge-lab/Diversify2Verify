    let nums = Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 (Cons 6 (Cons 7 (Cons 8 (Cons 9 (Cons 10 (Nil)))))))))) in
    let expected = Cons 54 (Cons 51 (Cons 46 (Cons 39 (Cons 30 (Cons 19 (Cons 6 (Cons 9 (Cons 26 (Cons 45 (Nil)))))))))) in
    let result = left_and_right_sum_differences_list nums in
