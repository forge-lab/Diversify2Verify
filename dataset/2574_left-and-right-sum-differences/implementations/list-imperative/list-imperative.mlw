module LeftAndRightSumDifferences_List_Imperative

  use int.Int
  use int.Abs
  use list.List
  use ref.Ref

  exception NotEqual

  let reverse_list (l: list int) : list int =
    let acc = ref (Nil : list int) in
    let cur = ref l in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons x xs ->
          acc := Cons x !acc;
          cur := xs
      end
    done;
    !acc

  let sum_list (l: list int) : int =
    let total = ref 0 in
    let cur = ref l in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons x xs ->
          total := !total + x;
          cur := xs
      end
    done;
    !total

  let list_eq_int (xs: list int) (ys: list int) : bool =
    try
      let left = ref xs in
      let right = ref ys in
      while (match !left, !right with Cons _ _, Cons _ _ -> true | _, _ -> false end) do
        match !left, !right with
        | Cons x xs1, Cons y ys1 ->
            if x = y then () else raise NotEqual;
            left := xs1;
            right := ys1
        | _, _ -> ()
        end
      done;
      match !left, !right with
      | Nil, Nil -> true
      | _, _ -> false
      end
    with NotEqual ->
      false
    end

  let left_and_right_sum_differences_list (nums: list int) : list int =
    let total = sum_list nums in
    let left = ref 0 in
    let remaining = ref total in
    let cur = ref nums in
    let out_rev = ref (Nil : list int) in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons x xs ->
          remaining := !remaining - x;
          out_rev := Cons (abs (!left - !remaining)) !out_rev;
          left := !left + x;
          cur := xs
      end
    done;
    reverse_list !out_rev

  let test_000 () : bool =
    let nums = Cons 5 (Cons 4 (Cons 3 (Cons 2 (Cons 1 Nil)))) in
    let expected = Cons 10 (Cons 1 (Cons 6 (Cons 11 (Cons 14 Nil)))) in
    let result = left_and_right_sum_differences_list nums in
    list_eq_int result expected

  let test_001 () : bool =
    let nums = Cons 1 Nil in
    let expected = Cons 0 Nil in
    let result = left_and_right_sum_differences_list nums in
    list_eq_int result expected

