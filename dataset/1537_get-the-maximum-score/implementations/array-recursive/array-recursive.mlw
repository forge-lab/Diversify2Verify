module GetTheMaximumScore_Array_Recursive_Implementation

  use int.Int
  use int.MinMax
  use int.EuclideanDivision
  use array.Array
  use array.Init

  let rec suffix_sum (nums: array int) (i: int) : int
    variant { length nums - i }
  =
    if i >= length nums then
      0
    else
      nums[i] + suffix_sum nums (i + 1)

  let rec max_score_scan
      (nums1: array int) (nums2: array int)
      (i: int) (j: int) (acc1: int) (acc2: int) : int
    variant { (length nums1 - i) + (length nums2 - j) }
  =
    if i >= length nums1 then
      max acc1 (acc2 + suffix_sum nums2 j)
    else if j >= length nums2 then
      max (acc1 + suffix_sum nums1 i) acc2
    else if nums1[i] < nums2[j] then
      max_score_scan nums1 nums2 (i + 1) j (acc1 + nums1[i]) acc2
    else if nums1[i] > nums2[j] then
      max_score_scan nums1 nums2 i (j + 1) acc1 (acc2 + nums2[j])
    else
      let merged = max acc1 acc2 + nums1[i] in
      merged + max_score_scan nums1 nums2 (i + 1) (j + 1) 0 0

  let maximum_path_score (nums1: array int) (nums2: array int) : int =
    max_score_scan nums1 nums2 0 0 0 0

  let get_the_maximum_score_array (nums1: array int) (nums2: array int) : int =
    mod (maximum_path_score nums1 nums2) 1000000007

  let test_000 () : bool =
    let nums1 = init 1 [|10000000|] in
    let nums2 = init 1 [|10000000|] in
    let r = get_the_maximum_score_array nums1 nums2 in
    r = 10000000

  let test_001 () : bool =
    let nums1 = init 5 [|2; 4; 5; 8; 10|] in
    let nums2 = init 4 [|4; 6; 8; 9|] in
    let r = get_the_maximum_score_array nums1 nums2 in
    r = 30

  let test_002 () : bool =
    let nums1 = init 3 [|1; 2; 3|] in
    let nums2 = init 7 [|4; 5; 6; 7; 8; 9; 10|] in
    let r = get_the_maximum_score_array nums1 nums2 in
    r = 49

