module GetTheMaximumScore_List_Recursive_Implementation

  use int.Int
  use int.MinMax
  use int.EuclideanDivision
  use list.List

  let rec max_score_acc (xs: list int) (ys: list int) (acc1: int) (acc2: int) : int
    variant { xs, ys }
  =
    match xs, ys with
    | Nil, Nil -> max acc1 acc2
    | Nil, Cons y ys_tail -> max_score_acc Nil ys_tail acc1 (acc2 + y)
    | Cons x xs_tail, Nil -> max_score_acc xs_tail Nil (acc1 + x) acc2
    | Cons x xs_tail, Cons y ys_tail ->
        if x < y then
          max_score_acc xs_tail ys (acc1 + x) acc2
        else if y < x then
          max_score_acc xs ys_tail acc1 (acc2 + y)
        else
          let joined = max acc1 acc2 + x in
          max_score_acc xs_tail ys_tail joined joined
    end

  let max_score (nums1: list int) (nums2: list int) : int =
    max_score_acc nums1 nums2 0 0

  let get_the_maximum_score_list (nums1: list int) (nums2: list int) : int =
    mod (max_score nums1 nums2) 1000000007

  let test_000 () : bool =
    let nums1 = Cons 10000000 Nil in
    let nums2 = Cons 10000000 Nil in
    let r = get_the_maximum_score_list nums1 nums2 in
    r = 10000000

  let test_001 () : bool =
    let nums1 = Cons 2 (Cons 4 (Cons 5 (Cons 8 (Cons 10 Nil)))) in
    let nums2 = Cons 4 (Cons 6 (Cons 8 (Cons 9 Nil))) in
    let r = get_the_maximum_score_list nums1 nums2 in
    r = 30

  let test_002 () : bool =
    let nums1 = Cons 1 (Cons 2 (Cons 3 Nil)) in
    let nums2 = Cons 4 (Cons 5 (Cons 6 (Cons 7 (Cons 8 (Cons 9 (Cons 10 Nil)))))) in
    let r = get_the_maximum_score_list nums1 nums2 in
    r = 49

  let test_003 () : bool =
    let nums1 = Cons 1 (Cons 2 (Cons 3 Nil)) in
    let nums2 = Cons 3 (Cons 4 (Cons 5 (Cons 6 (Cons 7 (Cons 8 (Cons 9 (Cons 10 Nil))))))) in
    let r = get_the_maximum_score_list nums1 nums2 in
    r = 55

