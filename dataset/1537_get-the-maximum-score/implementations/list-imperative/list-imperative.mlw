  let test_013 () : bool =
    let nums1 = Cons 10 (Cons 20 (Cons 30 (Cons 40 Nil))) in
    let nums2 = Cons 5 (Cons 15 (Cons 25 (Cons 35 (Cons 45 Nil)))) in
