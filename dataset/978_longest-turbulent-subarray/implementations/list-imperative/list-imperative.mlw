module LongestTurbulentSubarray_List_Imperative_Implementation

  use int.Int
  use list.List
  use ref.Ref

  let longest_turbulent_subarray_list (arr: list int) : int =
    match arr with
    | Nil -> 0
    | Cons first rest ->
        let prev = ref first in
        let dir = ref 0 in
        let cur_len = ref 1 in
        let best = ref 1 in
        let cur = ref rest in
        while (match !cur with Nil -> false | Cons _ _ -> true end) do
          match !cur with
          | Nil -> ()
          | Cons x xs ->
              if x = !prev then (
                cur_len := 1;
                dir := 0
              ) else (
                let cmp = if !prev < x then 1 else (-1) in
                if !dir = 0 then (
                  cur_len := 2;
                  dir := cmp
                ) else if cmp <> !dir then (
                  cur_len := !cur_len + 1;
                  dir := cmp
                ) else (
                  cur_len := 2;
                  dir := cmp
                )
              );
              if !cur_len > !best then best := !cur_len;
              prev := x;
              cur := xs
          end
        done;
        !best
    end

  let test_000 () : bool =
    let arr = Cons 9 (Cons 9 Nil) in
    let r = longest_turbulent_subarray_list arr in
    r = 1

  let test_001 () : bool =
    let arr = Cons 9 (Cons 4 (Cons 2 (Cons 10 (Cons 7 (Cons 8 (Cons 8 (Cons 1 (Cons 9 Nil)))))))) in
    let r = longest_turbulent_subarray_list arr in
    r = 5

  let test_002 () : bool =
    let arr = Cons 9 (Cons 8 (Cons 7 (Cons 6 (Cons 7 (Cons 8 (Cons 9 (Cons 8 (Cons 7 (Cons 6 Nil))))))))) in
    let r = longest_turbulent_subarray_list arr in
    r = 3

  let test_003 () : bool =
    let arr = Cons 1 (Cons 2 (Cons 1 (Cons 2 (Cons 1 (Cons 2 (Cons 1 (Cons 2 (Cons 3 Nil)))))))) in
    let r = longest_turbulent_subarray_list arr in
    r = 8

  let test_004 () : bool =
