  let test_013 () : bool =
    let arr = Cons 0 (Cons 8 (Cons 45 (Cons 88 (Cons 48 (Cons 68 (Cons 28 (Cons 55 (Cons 17 (Cons 24 Nil))))))))) in
    let r = longest_turbulent_subarray_list arr in
