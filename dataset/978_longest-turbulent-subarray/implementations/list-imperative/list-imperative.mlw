  let test_015 () : bool =
    let arr = Cons 8 (Cons 8 (Cons 8 (Cons 8 (Cons 8 (Cons 8 Nil))))) in
    let r = longest_turbulent_subarray_list arr in
    r = 1

  let test_016 () : bool =
    let arr = Cons 9 (Cons 8 (Cons 7 (Cons 6 (Cons 5 (Cons 4 (Cons 3 (Cons 2 (Cons 1 Nil)))))))) in
    let r = longest_turbulent_subarray_list arr in
