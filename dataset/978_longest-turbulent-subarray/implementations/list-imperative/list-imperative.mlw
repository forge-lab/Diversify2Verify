  let test_018 () : bool =
    let arr = Cons 4 (Cons 8 (Cons 12 (Cons 16 Nil))) in
    let r = longest_turbulent_subarray_list arr in
    r = 2

  let test_019 () : bool =
    let arr = Cons 1 (Cons 3 (Cons 2 (Cons 5 (Cons 4 (Cons 7 (Cons 6 (Cons 9 (Cons 8 (Cons 10 Nil))))))))) in
    let r = longest_turbulent_subarray_list arr in
    r = 10

  let run_tests () : bool =
    if test_000 () then
    if test_001 () then
    if test_002 () then
    if test_003 () then
    if test_004 () then
    if test_005 () then
    if test_006 () then
    if test_007 () then
    if test_008 () then
