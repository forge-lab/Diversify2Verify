  let test_011 () : bool =
    let arr = Cons 2 (Cons 1 (Cons 2 (Cons 1 (Cons 2 (Cons 1 (Cons 2 (Cons 1 (Cons 2 Nil)))))))) in
    let r = longest_turbulent_subarray_list arr in
    r = 9

  let test_012 () : bool =
    let arr = Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 (Cons 4 (Cons 3 (Cons 2 (Cons 1 Nil)))))))) in
    let r = longest_turbulent_subarray_list arr in
