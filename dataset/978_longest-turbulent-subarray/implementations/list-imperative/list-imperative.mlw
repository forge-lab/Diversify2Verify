  let test_017 () : bool =
    let arr = Cons 1 (Cons 2 (Cons 3 (Cons 2 (Cons 1 (Cons 2 (Cons 3 (Cons 2 (Cons 1 Nil)))))))) in
    let r = longest_turbulent_subarray_list arr in
