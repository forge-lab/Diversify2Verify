  let test_009 () : bool =
    let arr = Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 Nil)))))))) in
    let r = longest_turbulent_subarray_list arr in
    r = 1

  let test_010 () : bool =
    let arr = Cons 1 (Cons 2 (Cons 2 (Cons 1 (Cons 2 (Cons 2 (Cons 1 (Cons 2 (Cons 2 Nil)))))))) in
    let r = longest_turbulent_subarray_list arr in
