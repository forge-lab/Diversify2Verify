module WidestPairOfIndicesWithEqualRangeSum_List_Imperative

  use int.Int
  use list.List
  use ref.Ref

  let widest_pair_of_indices_with_equal_range_sum_list (nums1: list int) (nums2: list int) : int =
    let best = ref 0 in
    let start1 = ref nums1 in
    let start2 = ref nums2 in
    while (match !start1, !start2 with
           | Cons _ _, Cons _ _ -> true
           | _, _ -> false
           end) do
      let cur1 = ref !start1 in
      let cur2 = ref !start2 in
      let diff = ref 0 in
      let width = ref 0 in
      while (match !cur1, !cur2 with
             | Cons _ _, Cons _ _ -> true
             | _, _ -> false
             end) do
        match !cur1, !cur2 with
        | Cons x xs, Cons y ys ->
            diff := !diff + x - y;
            width := !width + 1;
            if !diff = 0 then
              if !width > !best then best := !width else ();
            cur1 := xs;
            cur2 := ys
        | _, _ -> ()
        end
      done;
      match !start1, !start2 with
      | Cons _ xs, Cons _ ys ->
          start1 := xs;
          start2 := ys
      | _, _ -> ()
      end
    done;
    !best

  let test_000 () : bool =
    let nums1 = Cons 0 (Cons 1 Nil) in
    let nums2 = Cons 1 (Cons 1 Nil) in
    let r = widest_pair_of_indices_with_equal_range_sum_list nums1 nums2 in
    r = 1

  let test_001 () : bool =
    let nums1 = Cons 0 (Cons 1 (Cons 0 (Cons 1 (Cons 0 (Cons 1 (Cons 0 (Cons 1 Nil))))))) in
    let nums2 = Cons 1 (Cons 0 (Cons 1 (Cons 0 (Cons 1 (Cons 0 (Cons 1 (Cons 0 Nil))))))) in
    let r = widest_pair_of_indices_with_equal_range_sum_list nums1 nums2 in
    r = 8

  let test_002 () : bool =
    let nums1 = Cons 1 (Cons 0 (Cons 0 (Cons 1 (Cons 0 Nil)))) in
    let nums2 = Cons 0 (Cons 1 (Cons 1 (Cons 0 (Cons 1 Nil)))) in
