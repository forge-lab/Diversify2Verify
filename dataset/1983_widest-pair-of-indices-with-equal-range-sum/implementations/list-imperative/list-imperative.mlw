  let test_019 () : bool =
    let nums1 =
      Cons 1 (Cons 1 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 1 (Cons 1 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 1 (Cons 1 (Cons 0 (Cons 0 (Cons 0 (Cons 0 Nil))))))))))))))))) in
    let nums2 =
      Cons 0 (Cons 0 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 0 (Cons 0 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 0 (Cons 0 (Cons 1 (Cons 1 (Cons 1 (Cons 1 Nil))))))))))))))))) in
    let r = widest_pair_of_indices_with_equal_range_sum_list nums1 nums2 in
    r = 8

  let run_tests () : bool =
