module WidestPairOfIndicesWithEqualRangeSum_Array_Recursive_Implementation

  use int.Int
  use array.Array
  use array.Init

  predicate binary_value (x: int) =
    x = 0 \/ x = 1

  predicate valid_binary_arrays (nums1: array int) (nums2: array int) =
    length nums1 = length nums2 /\
    1 <= length nums1 /\
    (forall k: int.
      0 <= k < length nums1 ->
      binary_value nums1[k] /\ binary_value nums2[k])

  let rec widest_from_start
    (nums1: array int) (nums2: array int)
    (start: int) (finish: int) (diff: int) (best: int) : int
    requires { length nums1 = length nums2 }
    requires { 0 <= start <= finish <= length nums1 }
    variant { length nums1 - finish }
  =
    if finish >= length nums1 then
      best
    else
      let next_diff = diff + nums1[finish] - nums2[finish] in
      let width = finish - start + 1 in
      let next_best =
        if next_diff = 0 then
          if best < width then width else best
        else
          best
      in
      widest_from_start nums1 nums2 start (finish + 1) next_diff next_best

  let rec widest_from_index
    (nums1: array int) (nums2: array int)
    (start: int) (best: int) : int
    requires { length nums1 = length nums2 }
    requires { 0 <= start <= length nums1 }
    variant { length nums1 - start }
  =
    if start >= length nums1 then
      best
    else
      let best_here = widest_from_start nums1 nums2 start start 0 best in
      widest_from_index nums1 nums2 (start + 1) best_here

  let widest_pair_of_indices_with_equal_range_sum_array
    (nums1: array int) (nums2: array int) : int
    requires { valid_binary_arrays nums1 nums2 }
  =
    widest_from_index nums1 nums2 0 0

  let test_000 () : bool =
    let nums1 = init 2 [|0; 1|] in
    let nums2 = init 2 [|1; 1|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 1

  let test_001 () : bool =
    let nums1 = init 8 [|0; 1; 0; 1; 0; 1; 0; 1|] in
    let nums2 = init 8 [|1; 0; 1; 0; 1; 0; 1; 0|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 8

  let test_002 () : bool =
    let nums1 = init 5 [|1; 0; 0; 1; 0|] in
    let nums2 = init 5 [|0; 1; 1; 0; 1|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 4

