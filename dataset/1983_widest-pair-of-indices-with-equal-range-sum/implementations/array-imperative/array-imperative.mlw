module WidestPairOfIndicesWithEqualRangeSum_Array_Imperative

  use int.Int
  use array.Array
  use array.Init
  use ref.Ref

  predicate binary_value (x: int) =
    x = 0 \/ x = 1

  predicate valid_binary_arrays (nums1: array int) (nums2: array int) =
    length nums1 = length nums2 /\
    1 <= length nums1 /\
    (forall k: int.
      0 <= k < length nums1 ->
      binary_value nums1[k] /\ binary_value nums2[k])

  let widest_pair_of_indices_with_equal_range_sum_array
      (nums1: array int) (nums2: array int) : int
    requires { valid_binary_arrays nums1 nums2 }
  =
    let best = ref 0 in
    for i = 0 to length nums1 - 1 do
      let diff = ref 0 in
      for j = i to length nums1 - 1 do
        diff := !diff + nums1[j] - nums2[j];
        if !diff = 0 then
          let width = j - i + 1 in
          if width > !best then
            best := width
      done
    done;
    !best

  let test_000 () : bool =
    let nums1 = init 2 [|0; 1|] in
    let nums2 = init 2 [|1; 1|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 1

  let test_001 () : bool =
    let nums1 = init 8 [|0; 1; 0; 1; 0; 1; 0; 1|] in
    let nums2 = init 8 [|1; 0; 1; 0; 1; 0; 1; 0|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 8

  let test_002 () : bool =
    let nums1 = init 5 [|1; 0; 0; 1; 0|] in
    let nums2 = init 5 [|0; 1; 1; 0; 1|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 4

  let test_003 () : bool =
    let nums1 = init 5 [|0; 1; 0; 1; 0|] in
    let nums2 = init 5 [|1; 0; 1; 0; 1|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 4

  let test_004 () : bool =
    let nums1 = init 5 [|0; 0; 1; 1; 1|] in
    let nums2 = init 5 [|1; 1; 1; 0; 0|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 5

  let test_005 () : bool =
    let nums1 = init 5 [|1; 0; 0; 0; 0|] in
    let nums2 = init 5 [|0; 0; 0; 0; 1|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 5

  let test_006 () : bool =
    let nums1 = init 5 [|1; 1; 1; 0; 0|] in
    let nums2 = init 5 [|0; 0; 1; 1; 1|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 5

  let test_007 () : bool =
    let nums1 = init 5 [|1; 0; 1; 0; 1|] in
    let nums2 = init 5 [|1; 1; 0; 0; 1|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 5

  let test_008 () : bool =
    let nums1 = init 5 [|1; 1; 0; 0; 1|] in
    let nums2 = init 5 [|0; 0; 1; 1; 0|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 4

  let test_009 () : bool =
    let nums1 = init 5 [|0; 0; 0; 0; 0|] in
    let nums2 = init 5 [|0; 0; 0; 0; 0|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 5

  let test_010 () : bool =
    let nums1 = init 6 [|1; 1; 0; 0; 1; 1|] in
    let nums2 = init 6 [|1; 0; 1; 1; 0; 0|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 5

  let test_011 () : bool =
    let nums1 = init 4 [|1; 1; 0; 1|] in
    let nums2 = init 4 [|0; 1; 1; 0|] in
