    r = 2

  let test_013 () : bool =
    let nums1 = init 1 [|0|] in
    let nums2 = init 1 [|1|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 0

  let test_014 () : bool =
    let nums1 = init 7 [|1; 0; 1; 0; 1; 0; 1|] in
    let nums2 = init 7 [|0; 1; 0; 1; 0; 1; 0|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 6

  let test_015 () : bool =
    let nums1 = init 5 [|1; 0; 1; 0; 1|] in
    let nums2 = init 5 [|0; 1; 0; 1; 0|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 4

  let test_016 () : bool =
    let nums1 = init 5 [|1; 1; 1; 1; 1|] in
    let nums2 = init 5 [|1; 1; 1; 1; 1|] in
    let r = widest_pair_of_indices_with_equal_range_sum_array nums1 nums2 in
    r = 5

  let test_017 () : bool =
    let nums1 = init 6 [|1; 1; 0; 0; 1; 1|] in
    let nums2 = init 6 [|1; 0; 1; 0; 1; 0|] in
