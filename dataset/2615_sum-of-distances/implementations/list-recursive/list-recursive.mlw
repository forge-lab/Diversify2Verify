module SumOfDistances_List_Recursive_Implementation

  use int.Int
  use int.Abs
  use list.List

  let rec distance_sum_from
      (target: int) (target_index: int) (current_index: int) (nums: list int) : int
    variant { nums }
  =
    match nums with
    | Nil -> 0
    | Cons x xs ->
        (if x = target then
           if current_index = target_index then 0
           else abs (target_index - current_index)
         else 0) + distance_sum_from target target_index (current_index + 1) xs
    end

  let rec distances_for
      (all_nums: list int) (current_index: int) (suffix: list int) : list int
    variant { suffix }
  =
    match suffix with
    | Nil -> Nil
    | Cons x xs ->
        Cons (distance_sum_from x current_index 0 all_nums)
          (distances_for all_nums (current_index + 1) xs)
    end

  let sum_of_distances_list (nums: list int) : list int =
    distances_for nums 0 nums

  let rec same_list (xs: list int) (ys: list int) : bool
    variant { xs }
  =
    match xs, ys with
    | Nil, Nil -> true
    | Cons x xt, Cons y yt -> if x = y then same_list xt yt else false
    | _, _ -> false
    end

  let rec append_list (xs: list int) (ys: list int) : list int
    variant { xs }
  =
    match xs with
    | Nil -> ys
    | Cons x xt -> Cons x (append_list xt ys)
    end

  let test_000 () : bool =
    let nums = Cons 0 (Cons 5 (Cons 3 Nil)) in
    let expected = Cons 0 (Cons 0 (Cons 0 Nil)) in
    let r = sum_of_distances_list nums in
    same_list r expected

  let test_001 () : bool =
    let nums =
      Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5
        (Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 Nil))))))))) in
    let expected =
      Cons 5 (Cons 5 (Cons 5 (Cons 5 (Cons 5
        (Cons 5 (Cons 5 (Cons 5 (Cons 5 (Cons 5 Nil))))))))) in
    let r = sum_of_distances_list nums in
    same_list r expected

