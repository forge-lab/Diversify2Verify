    let nums_back =
      Cons 10 (Cons 9 (Cons 8 (Cons 7 (Cons 6
        (Cons 5 (Cons 4 (Cons 3 (Cons 2 (Cons 1 Nil))))))))) in
    let nums = append_list nums_front nums_back in
    let zeros10 = Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 Nil))))))))) in
    let expected = append_list zeros10 zeros10 in
    let r = sum_of_distances_list nums in
    same_list r expected

