  let test_019 () : bool =
    let nums = Cons 50 (Cons 50 (Cons 40 (Cons 40 (Cons 40 (Cons 30 (Cons 30 (Cons 30 (Cons 30 (Cons 20 (Cons 20 (Cons 20 (Cons 20 (Cons 20 (Cons 10 (Cons 10 (Cons 10 (Cons 10 (Cons 10 (Cons 10 (Nil)))))))))))))))))))) in
    let expected = Cons 1 (Cons 1 (Cons 3 (Cons 2 (Cons 3 (Cons 6 (Cons 4 (Cons 4 (Cons 6 (Cons 10 (Cons 7 (Cons 6 (Cons 7 (Cons 10 (Cons 15 (Cons 11 (Cons 9 (Cons 9 (Cons 11 (Cons 15 (Nil)))))))))))))))))))) in
    check_case nums expected

  let run_tests () : bool =
