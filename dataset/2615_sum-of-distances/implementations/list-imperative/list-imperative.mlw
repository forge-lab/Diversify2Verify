  let test_018 () : bool =
    let nums = Cons 9 (Cons 8 (Cons 7 (Cons 6 (Cons 5 (Cons 4 (Cons 3 (Cons 2 (Cons 1 (Cons 9 (Cons 8 (Cons 7 (Cons 6 (Cons 5 (Cons 4 (Cons 3 (Cons 2 (Cons 1 (Cons 9 (Cons 8 (Cons 7 (Cons 6 (Cons 5 (Cons 4 (Cons 3 (Cons 2 (Cons 1 (Nil))))))))))))))))))))))))))) in
    let expected = Cons 27 (Cons 27 (Cons 27 (Cons 27 (Cons 27 (Cons 27 (Cons 27 (Cons 27 (Cons 27 (Cons 18 (Cons 18 (Cons 18 (Cons 18 (Cons 18 (Cons 18 (Cons 18 (Cons 18 (Cons 18 (Cons 27 (Cons 27 (Cons 27 (Cons 27 (Cons 27 (Cons 27 (Cons 27 (Cons 27 (Cons 27 (Nil))))))))))))))))))))))))))) in
