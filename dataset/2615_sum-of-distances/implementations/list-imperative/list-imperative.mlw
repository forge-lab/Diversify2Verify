module SumOfDistances_List_Imperative_Implementation

  use int.Int
  use int.Abs
  use list.List
  use ref.Ref

  exception Different

  let reverse_list (l: list int) : list int =
    let acc = ref Nil in
    let cur = ref l in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons x xs ->
          acc := Cons x !acc;
          cur := xs
      end
    done;
    !acc

  let sum_of_distances_list (nums: list int) : list int =
    let rev_result = ref Nil in
    let outer = ref nums in
    let target_index = ref 0 in
    while (match !outer with Nil -> false | Cons _ _ -> true end) do
      match !outer with
      | Nil -> ()
      | Cons target rest_outer ->
          let total = ref 0 in
          let inner = ref nums in
          let current_index = ref 0 in
          while (match !inner with Nil -> false | Cons _ _ -> true end) do
            match !inner with
            | Nil -> ()
            | Cons x xs ->
                if x = target then
                  if !current_index = !target_index then ()
                  else total := !total + abs (!target_index - !current_index);
                inner := xs;
                current_index := !current_index + 1
            end
          done;
          rev_result := Cons !total !rev_result;
          outer := rest_outer;
          target_index := !target_index + 1
      end
    done;
    reverse_list !rev_result

  let equal_list (xs: list int) (ys: list int) : bool =
    try
      let cur_x = ref xs in
      let cur_y = ref ys in
      while (match !cur_x, !cur_y with Cons _ _, Cons _ _ -> true | _, _ -> false end) do
        match !cur_x, !cur_y with
        | Cons x xt, Cons y yt ->
            if x <> y then raise Different;
            cur_x := xt;
            cur_y := yt
        | _, _ -> ()
        end
      done;
      match !cur_x, !cur_y with
      | Nil, Nil -> true
      | _, _ -> false
      end
    with Different ->
      false
    end

  let check_case (nums: list int) (expected: list int) : bool =
    let r = sum_of_distances_list nums in
    equal_list r expected

  let test_000 () : bool =
    let nums = Cons 0 (Cons 5 (Cons 3 Nil)) in
    let expected = Cons 0 (Cons 0 (Cons 0 Nil)) in
    check_case nums expected

  let test_001 () : bool =
    let nums =
      Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5
        (Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 Nil))))))))) in
    let expected =
      Cons 5 (Cons 5 (Cons 5 (Cons 5 (Cons 5
        (Cons 5 (Cons 5 (Cons 5 (Cons 5 (Cons 5 Nil))))))))) in
    check_case nums expected

  let test_002 () : bool =
    let nums = Cons 1 Nil in
    let expected = Cons 0 Nil in
    check_case nums expected

  let test_003 () : bool =
