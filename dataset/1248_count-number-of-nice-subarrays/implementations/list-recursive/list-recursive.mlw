  let test_022 () : bool =
    let nums = Cons 2 (Cons 2 (Cons 2 (Cons 1 (Cons 2 (Cons 2 (Cons 2 (Cons 1 (Cons 2 (Cons 2 (Cons 2 (Cons 1 (Cons 2 (Cons 2 (Cons 2 (Cons 1 (Cons 2 (Cons 2 (Cons 2 (Nil))))))))))))))))))) in
    let r = count_number_of_nice_subarrays_list nums 4 in
    r = 16

