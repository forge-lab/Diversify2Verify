module MinimumConsecutiveCardsToPickUp_List_Recursive_Implementation

  use int.Int
  use list.List

  let min_positive (left: int) (right: int) : int =
    if left = -1 then right else if right = -1 then left else if left <= right then left else right

  let rec distance_to_next_match (card: int) (cards: list int) (span: int) : int
    variant { cards }
  =
    match cards with
    | Nil -> -1
    | Cons x xs ->
        if x = card then span else distance_to_next_match card xs (span + 1)
    end

  let rec minimum_consecutive_cards_to_pick_up_list (cards: list int) : int
    variant { cards }
  =
    match cards with
    | Nil -> -1
    | Cons x xs ->
        let current = distance_to_next_match x xs 2 in
        let rest = minimum_consecutive_cards_to_pick_up_list xs in
        min_positive current rest
    end

  let test_009 () : bool =
    let cards = Cons 5 Nil in
    let result = minimum_consecutive_cards_to_pick_up_list cards in
    result = -1

  let test_005 () : bool =
    let cards = Cons 0 (Cons 0 Nil) in
    let result = minimum_consecutive_cards_to_pick_up_list cards in
    result = 2

  let test_006 () : bool =
    let cards = Cons 1 (Cons 1 Nil) in
    let result = minimum_consecutive_cards_to_pick_up_list cards in
    result = 2

  let test_011 () : bool =
    let cards = Cons 1000000 (Cons 999999 (Cons 1000000 Nil)) in
    let result = minimum_consecutive_cards_to_pick_up_list cards in
    result = 3

  let test_014 () : bool =
