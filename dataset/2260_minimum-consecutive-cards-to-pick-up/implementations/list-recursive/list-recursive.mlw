  let test_108 () : bool =
    let cards = Cons 100000 (Cons 200000 (Cons 300000 (Cons 400000 (Cons 500000 (Cons 100000 (Cons 200000 (Cons 300000 (Cons 400000 (Cons 500000 Nil))))))))) in
    let result = minimum_consecutive_cards_to_pick_up_list cards in
    result = 6

  let test_000 () : bool =
    let cards = Cons 0 (Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 (Cons 6 (Cons 7 (Cons 8 (Cons 9 (Cons 0 Nil)))))))))) in
    let result = minimum_consecutive_cards_to_pick_up_list cards in
    result = 11

  let test_045 () : bool =
    let cards = Cons 1000 (Cons 2000 (Cons 3000 (Cons 4000 (Cons 5000 (Cons 6000 (Cons 7000 (Cons 8000 (Cons 9000 (Cons 10000 (Cons 1000 Nil)))))))))) in
    let result = minimum_consecutive_cards_to_pick_up_list cards in
    result = 11

