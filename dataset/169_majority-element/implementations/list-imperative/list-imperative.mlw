module MajorityElement_List_Imperative_Implementation

  use int.Int
  use list.List
  use ref.Ref

  let majority_element_list (nums: list int) : int =
    match nums with
    | Nil -> 0
    | Cons h t ->
        let candidate = ref h in
        let balance = ref 1 in
        let cur = ref t in
        while (match !cur with Nil -> false | Cons _ _ -> true end) do
          match !cur with
          | Nil -> ()
          | Cons x xs ->
              if !balance = 0 then (
                candidate := x;
                balance := 1
              ) else if x = !candidate then
                balance := !balance + 1
              else
                balance := !balance - 1;
              cur := xs
          end
        done;
        !candidate
    end

  let test_test_000 () : bool =
    let l = Cons 1 (Cons 1 (Cons 2 (Cons 2 (Cons 2 (Cons 2 (Cons 2 Nil)))))) in
    let r = majority_element_list l in
    r = 2

  let test_test_001 () : bool =
    let l = Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 2 (Cons 2 (Cons 3 Nil)))))) in
    let r = majority_element_list l in
    r = 1

  let test_test_002 () : bool =
    let l = Cons 2 (Cons 2 (Cons 1 (Cons 1 (Cons 1 (Cons 2 (Cons 2 Nil)))))) in
    let r = majority_element_list l in
    r = 2

  let test_test_003 () : bool =
    let l = Cons (-1) (Cons 100 (Cons (-1) (Cons (-1) (Cons (-1) (Cons (-1)
      (Cons 1 (Cons 1 (Cons 1 (Cons 1 Nil))))))))) in
    let r = majority_element_list l in
    r = (-1)

  let test_test_004 () : bool =
    let l = Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 (Cons 4 (Cons 4 (Cons 4
      (Cons 4 Nil)))))))) in
    let r = majority_element_list l in
    r = 4

  let test_test_005 () : bool =
    let l = Cons 4 (Cons 4 (Cons 4 (Cons 4 (Cons 2 (Cons 2 (Cons 3 Nil)))))) in
    let r = majority_element_list l in
    r = 4

  let test_test_006 () : bool =
    let l = Cons 1000000000 (Cons 1000000000 (Cons 1000000000
      (Cons 1000000000 (Cons 1000000000 (Cons 1000000000
      (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 Nil)))))))))) in
    let r = majority_element_list l in
    r = 1000000000

  let test_test_007 () : bool =
