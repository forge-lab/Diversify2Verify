module CountTheNumberOfFairPairs_List_Recursive_Implementation

  use int.Int
  use list.List

  let rec count_fair_with (x: int) (ys: list int) (lower: int) (upper: int) : int
    variant { ys }
  =
    match ys with
    | Nil -> 0
    | Cons y rest ->
        let pair_sum = x + y in
        (if lower <= pair_sum && pair_sum <= upper then 1 else 0) +
        count_fair_with x rest lower upper
    end

  let rec count_the_number_of_fair_pairs_list (nums: list int) (lower: int) (upper: int) : int
    variant { nums }
  =
    match nums with
    | Nil -> 0
    | Cons x rest ->
        count_fair_with x rest lower upper +
        count_the_number_of_fair_pairs_list rest lower upper
    end

  let test_000 () : bool =
    let nums = Cons 1000000000 (Cons (-1000000000) (Cons 500000000 (Cons (-500000000) Nil))) in
    let r = count_the_number_of_fair_pairs_list nums 0 0 in
    r = 2

  let test_001 () : bool =
    let nums = Cons 0 (Cons 1 (Cons 7 (Cons 4 (Cons 4 (Cons 5 Nil))))) in
    let r = count_the_number_of_fair_pairs_list nums 3 6 in
    r = 6

  let test_002 () : bool =
    let nums = Cons 5 (Cons 5 (Cons 5 (Cons 5 (Cons 5 Nil)))) in
    let r = count_the_number_of_fair_pairs_list nums 10 10 in
    r = 10

  let test_003 () : bool =
