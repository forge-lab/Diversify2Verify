    let r = find_the_student_that_will_replace_the_chalk_array chalk 987654321 in
    r = 8

  let test_017 () : bool =
    let chalk = init 9 [|9; 8; 7; 6; 5; 4; 3; 2; 1|] in
    let r = find_the_student_that_will_replace_the_chalk_array chalk 1200000000 in
