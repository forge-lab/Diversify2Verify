  let test_test_018 () : bool =
    let arr1 = Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Nil))))) in
    let arr2 = Cons 2 (Cons 2 (Cons 2 (Cons 2 (Cons 2 (Nil))))) in
