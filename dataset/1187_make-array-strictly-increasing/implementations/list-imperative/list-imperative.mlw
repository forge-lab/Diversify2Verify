module MakeArrayStrictlyIncreasing_List_Imperative

  use int.Int
  use list.List
  use ref.Ref

  type state = State int int

  let reverse_states (states: list state) : list state =
    let acc = ref (Nil : list state) in
    let cur = ref states in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons st rest ->
          acc := Cons st !acc;
          cur := rest
      end
    done;
    !acc

  let add_state_min (states: list state) (last: int) (cost: int) : list state =
    let acc = ref (Nil : list state) in
    let cur = ref states in
    let found = ref false in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons st rest ->
          begin
            match st with
            | State existing_last existing_cost ->
                if existing_last = last then begin
                  found := true;
                  if cost < existing_cost then
                    acc := Cons (State last cost) !acc
                  else
                    acc := Cons st !acc
                end else
                  acc := Cons st !acc
            end;
            cur := rest
          end
      end
    done;
    let rebuilt = reverse_states !acc in
    if !found then rebuilt else Cons (State last cost) rebuilt

  let add_replacements_above
      (arr2: list int) (last: int) (cost: int) (states: list state) : list state =
    let next = ref states in
    let cur = ref arr2 in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons y ys ->
          if y > last then
            next := add_state_min !next y (cost + 1)
          else ();
          cur := ys
      end
    done;
    !next

  let add_initial_replacements (arr2: list int) (states: list state) : list state =
    let next = ref states in
    let cur = ref arr2 in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons y ys ->
          next := add_state_min !next y 1;
          cur := ys
      end
    done;
    !next

  let step_states (states: list state) (arr2: list int) (x: int) : list state =
    let next = ref (Nil : list state) in
    let cur = ref states in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons st rest ->
          begin
            match st with
            | State last cost ->
                if x > last then
                  next := add_state_min !next x cost
                else ();
                next := add_replacements_above arr2 last cost !next
            end;
            cur := rest
          end
      end
    done;
    !next

  let min_cost (states: list state) : int =
    let best = ref (-1) in
    let cur = ref states in
    while (match !cur with Nil -> false | Cons _ _ -> true end) do
      match !cur with
      | Nil -> ()
      | Cons st rest ->
          begin
            match st with
            | State _ cost ->
                if !best = -1 then
                  best := cost
                else if cost < !best then
                  best := cost
                else ()
            end;
            cur := rest
          end
      end
    done;
    !best

  let make_array_strictly_increasing_list (arr1: list int) (arr2: list int) : int =
    match arr1 with
    | Nil -> 0
    | Cons x xs ->
        let states = ref (Nil : list state) in
        states := add_state_min !states x 0;
        states := add_initial_replacements arr2 !states;
        let cur = ref xs in
        while (match !cur with Nil -> false | Cons _ _ -> true end) do
          match !cur with
          | Nil -> ()
          | Cons y ys ->
              states := step_states !states arr2 y;
              cur := ys
          end
        done;
        min_cost !states
    end

  let test_test_000 () : bool =
    let arr1 = Cons 1 (Cons 3 (Cons 5 (Cons 7 (Nil)))) in
    let arr2 = Cons 2 (Cons 4 (Cons 6 (Cons 8 (Nil)))) in
    let r = make_array_strictly_increasing_list arr1 arr2 in
    r = 0

  let test_test_001 () : bool =
    let arr1 = Cons 1 (Cons 5 (Cons 3 (Cons 6 (Cons 7 (Nil))))) in
    let arr2 = Cons 1 (Cons 6 (Cons 3 (Cons 3 (Nil)))) in
    let r = make_array_strictly_increasing_list arr1 arr2 in
    r = -1

  let test_test_002 () : bool =
    let arr1 = Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 (Nil))))) in
    let arr2 = Cons 6 (Cons 7 (Cons 8 (Cons 9 (Nil)))) in
    let r = make_array_strictly_increasing_list arr1 arr2 in
    r = 0

  let test_test_003 () : bool =
