  let test_test_019 () : bool =
    let arr1 = Cons 1 (Cons 2000 (Nil)) in
    let arr2 = Cons 1000 (Nil) in
    let r = make_array_strictly_increasing_list arr1 arr2 in
    r = 0

  let run_tests () : bool =
    if test_test_000 () then
    if test_test_001 () then
