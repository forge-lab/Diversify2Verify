      "raw": "val maximize_happiness_of_selected_children_list (happiness: list int) (k: int) : int",
      "function_name": "maximize_happiness_of_selected_children_list",
      "parameters": [
        {
          "name": "happiness",
          "why3_type": "list int",
          "semantic_type": "int_sequence"
        },
        {
          "name": "k",
          "why3_type": "int",
          "semantic_type": "int"
        }
      ],
