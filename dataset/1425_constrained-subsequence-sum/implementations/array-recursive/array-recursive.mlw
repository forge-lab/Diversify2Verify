module ConstrainedSubsequenceSum_Array_Recursive_Implementation

  use int.Int
  use array.Array
  use array.Init

  predicate input_valid (nums: array int) (k: int) =
    1 <= k <= length nums <= 100000 /\
    forall i: int. 0 <= i < length nums -> (-10000) <= nums[i] <= 10000

  let rec max_prev_from (dp: array int) (j: int) (stop: int) (best: int) : int
    requires { 0 <= j <= stop <= length dp }
    variant { stop - j }
  =
    if j >= stop then
      best
    else
      let next_best = if dp[j] > best then dp[j] else best in
      max_prev_from dp (j + 1) stop next_best

  let rec fill_dp (nums: array int) (k: int) (dp: array int) (i: int) (best_so_far: int) : int
    requires { length nums = length dp }
    requires { 0 < length nums }
    requires { 1 <= k }
    requires { 1 <= i <= length nums }
    variant { length nums - i }
  =
    if i >= length nums then
      best_so_far
    else
      let start = if i - k > 0 then i - k else 0 in
      let best_prev = max_prev_from dp start i 0 in
      let current = nums[i] + best_prev in
      dp[i] <- current;
      let next_best = if current > best_so_far then current else best_so_far in
      fill_dp nums k dp (i + 1) next_best

  let constrained_subsequence_sum_array (nums: array int) (k: int) : int
    requires { input_valid nums k }
  =
    let n = length nums in
    if n = 0 then
      0
    else
      let dp = make n 0 in
      dp[0] <- nums[0];
      fill_dp nums k dp 1 nums[0]

  let test_000_constrained_subsequence_sum () : bool =
    let nums = init 4 [|5; 7; -3; 5|] in
    let r = constrained_subsequence_sum_array nums 1 in
    r = 14

  let test_001_constrained_subsequence_sum () : bool =
    let nums = init 5 [|10; 2; -10; 5; 20|] in
    let r = constrained_subsequence_sum_array nums 2 in
    r = 37

