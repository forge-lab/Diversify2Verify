    check_case nums 2 23

  let test_011 () : bool =
    let nums = Cons 1 (Cons (-1) (Cons 2 (Cons (-2) (Cons 3 (Cons (-3) (Cons 4 (Cons (-4) (Cons 5 (Cons (-5) Nil))))))))) in
    check_case nums 2 15

  let test_012 () : bool =
    let nums = Cons 10 (Cons (-10) (Cons 20 (Cons (-20) (Cons 30 (Cons (-30) (Cons 40 (Cons (-40) (Cons 50 (Cons (-50) Nil))))))))) in
    check_case nums 2 150

  let test_013 () : bool =
    let nums = Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 (Cons 6 (Cons 7 (Cons 8 (Cons 9 (Cons 10 Nil))))))))) in
    check_case nums 10 55

  let test_014 () : bool =
    let nums = Cons (-1) (Cons (-2) (Cons (-3) (Cons (-4) (Cons (-5) (Cons (-6) (Cons (-7) (Cons (-8) (Cons (-9) (Cons (-10) (Cons (-11) (Cons (-12) (Cons (-13) (Cons (-14) (Cons (-15) (Cons (-16) (Cons (-17) (Cons (-18) (Cons (-19) (Cons (-20) Nil))))))))))))))))))) in
    check_case nums 5 (-1)

  let test_015 () : bool =
    let nums = Cons (-10) (Cons (-20) (Cons (-30) (Cons (-40) (Cons (-50) (Cons (-60) (Cons (-70) Nil)))))) in
    check_case nums 1 (-10)

  let test_016 () : bool =
    let nums = Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 (Cons 1 Nil))))))))))))))))))) in
    check_case nums 20 20

  let test_017 () : bool =
    let nums = Cons 10 (Cons (-10) (Cons 20 (Cons (-20) (Cons 30 (Cons (-30) (Cons 40 (Cons (-40) (Cons 50 (Cons (-50) Nil))))))))) in
    check_case nums 4 150

  let test_018 () : bool =
    let nums = Cons 1 (Cons (-1) (Cons 2 (Cons (-2) (Cons 3 (Cons (-3) (Cons 4 (Cons (-4) (Cons 5 (Cons (-5) (Cons 6 (Cons (-6) (Cons 7 (Cons (-7) (Cons 8 (Cons (-8) (Cons 9 (Cons (-9) (Cons 10 (Cons (-10) Nil))))))))))))))))))) in
    check_case nums 10 55

  let test_019 () : bool =
    let nums = Cons (-1) (Cons (-2) (Cons (-3) (Cons (-4) (Cons (-5) (Cons (-6) (Cons (-7) (Cons (-8) (Cons (-9) (Cons (-10) Nil))))))))) in
    check_case nums 5 (-1)

  let run_tests () : bool =
    if test_000 () then
    if test_001 () then
    if test_002 () then
    if test_003 () then
    if test_004 () then
    if test_005 () then
    if test_006 () then
    if test_007 () then
    if test_008 () then
    if test_009 () then
    if test_010 () then
