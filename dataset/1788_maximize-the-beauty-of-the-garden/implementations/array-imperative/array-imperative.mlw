module MaximizeTheBeautyOfTheGarden_Array_Imperative

  use int.Int
  use array.Array
  use array.Init
  use ref.Ref

  let maximize_the_beauty_of_the_garden_array (flowers: array int) : int =
    let n = length flowers in
    let positive_prefix = make (n + 1) 0 in
    for i = 0 to n - 1 do
      positive_prefix[i + 1] <- positive_prefix[i] +
        (if flowers[i] > 0 then flowers[i] else 0)
    done;
    let best = ref 0 in
    let found = ref false in
    for i = 0 to n - 2 do
      for j = i + 1 to n - 1 do
        if flowers[i] = flowers[j] then
          let candidate =
            flowers[i] + flowers[j] + positive_prefix[j] - positive_prefix[i + 1]
          in
          if not !found then begin
            found := true;
            best := candidate
          end else if candidate > !best then
            best := candidate
      done
    done;
    !best

  let test_000 () : bool =
    let flowers = init 6 [|-10000; 10000; -10000; 10000; -10000; 10000|] in
    let r = maximize_the_beauty_of_the_garden_array flowers in
    r = 30000

  let test_001 () : bool =
    let flowers = init 7 [|5; 8; 5; 3; 5; 2; 5|] in
    let r = maximize_the_beauty_of_the_garden_array flowers in
    r = 33

  let test_002 () : bool =
    let flowers = init 5 [|100; 1; 1; -3; 1|] in
    let r = maximize_the_beauty_of_the_garden_array flowers in
    r = 3

  let test_003 () : bool =
