    check_case nums 1

  let test_008 () : bool =
    let nums =
      Cons 5 (Cons 5 (Cons 5 (Cons 5 (Cons 5
      (Cons 5 (Cons 5 (Cons 5 (Cons 5 (Cons 5 Nil))))))))) in
    check_case nums 8

  let test_010 () : bool =
