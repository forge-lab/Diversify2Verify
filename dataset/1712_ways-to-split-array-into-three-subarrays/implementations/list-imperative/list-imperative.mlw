  let test_011 () : bool =
    let nums = Cons 1 (Cons 3 (Cons 1 (Cons 1 (Cons 2 Nil)))) in
    check_case nums 1

  let test_012 () : bool =
    let nums = Cons 3 (Cons 2 (Cons 1 Nil)) in
    check_case nums 0

  let test_013 () : bool =
    let nums = Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 0 Nil)))) in
    check_case nums 6

  let test_014 () : bool =
    let nums = Cons 1 (Cons 2 (Cons 2 (Cons 2 (Cons 5 (Cons 0 Nil))))) in
    check_case nums 3

  let test_015 () : bool =
    let nums =
      Cons 9 (Cons 8 (Cons 7 (Cons 6 (Cons 5
      (Cons 4 (Cons 3 (Cons 2 (Cons 1 Nil)))))))) in
    check_case nums 1

  let test_016 () : bool =
    let nums =
      Cons 1 (Cons 0 (Cons 0 (Cons 0 (Cons 0
      (Cons 0 (Cons 0 (Cons 0 (Cons 0 (Cons 2 Nil))))))))) in
    check_case nums 0

  let test_017 () : bool =
    let nums = Cons 1 (Cons 3 (Cons 2 (Cons 2 (Cons 1 (Cons 1 Nil))))) in
    check_case nums 1

  let test_018 () : bool =
    let nums =
      Cons 1 (Cons 1 (Cons 2 (Cons 2 (Cons 3
      (Cons 3 (Cons 4 (Cons 4 (Cons 5 (Cons 5
      (Cons 6 (Cons 6 (Cons 7 (Cons 7 (Cons 8
      (Cons 8 (Cons 9 (Cons 9 (Cons 10 (Cons 10
      (Cons 11 (Cons 11 (Cons 12 (Cons 12 (Cons 13
      (Cons 13 (Cons 14 (Cons 14 (Cons 15 (Cons 15 Nil))))))))))))))))))))))))))))) in
    check_case nums 160

  let test_019 () : bool =
    let nums =
      Cons 10 (Cons 9 (Cons 8 (Cons 7 (Cons 6
      (Cons 5 (Cons 4 (Cons 3 (Cons 2 (Cons 1
      (Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5
      (Cons 6 (Cons 7 (Cons 8 (Cons 9 (Cons 10
      (Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5
      (Cons 6 (Cons 7 (Cons 8 (Cons 9 (Cons 10 Nil))))))))))))))))))))))))))))) in
    check_case nums 50

  let test_020 () : bool =
    let nums =
      Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5
      (Cons 6 (Cons 7 (Cons 8 (Cons 9 (Cons 10
      (Cons 11 (Cons 12 (Cons 13 (Cons 14 (Cons 15
      (Cons 16 (Cons 17 (Cons 18 (Cons 19 (Cons 20
      (Cons 1 (Cons 2 (Cons 3 (Cons 4 (Cons 5 Nil)))))))))))))))))))))))) in
    check_case nums 74

  let run_tests () : bool =
    if test_000 () then
    if test_001 () then
    if test_002 () then
    if test_003 () then
    if test_004 () then
    if test_005 () then
    if test_006 () then
    if test_007 () then
    if test_008 () then
    if test_010 () then
    if test_011 () then
    if test_012 () then
    if test_013 () then
    if test_014 () then
    if test_015 () then
    if test_016 () then
    if test_017 () then
    if test_018 () then
    if test_019 () then
    if test_020 () then
      true
    else false
    else false
    else false
