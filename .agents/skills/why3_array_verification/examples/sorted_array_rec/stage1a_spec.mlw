module Sorted_Array_Spec

  use int.Int
  use import array.Array
  use import array.Init

  predicate sorted_array (a: array int) =
    forall i j: int.
      0 <= i <= j < length a -> a[i] <= a[j]

  predicate pair_ok (a: array int) (i: int) (j: int) =
    0 <= i <= j < length a -> a[i] <= a[j]

  val is_sorted_array (a: array int) : bool
    ensures { result <-> sorted_array a }

  let lemma check_sorted_array_1 () =
    let a = init 4 [|1; 2; 2; 5|] in
    assert { length a = 4 };

    assert { pair_ok a 0 0 };
    assert { pair_ok a 0 1 };
    assert { pair_ok a 0 2 };
    assert { pair_ok a 0 3 };

    assert { pair_ok a 1 1 };
    assert { pair_ok a 1 2 };
    assert { pair_ok a 1 3 };

    assert { pair_ok a 2 2 };
    assert { pair_ok a 2 3 };

    assert { pair_ok a 3 3 };

    assert {
      forall k:int. 0 <= k < length a ->
        k = 0 \/ k = 1 \/ k = 2 \/ k = 3
    };

    assert { sorted_array a }

  let lemma check_sorted_array_2 () =
    let a = init 1 [|7|] in
    assert { length a = 1 };

    assert { pair_ok a 0 0 };

    assert {
      forall k:int. 0 <= k < length a ->
        k = 0
    };

    assert { sorted_array a }

  let lemma check_sorted_array_3 () =
    let a = init 4 [|1; 3; 2; 5|] in
    assert { length a = 4 };

    (* Counterexample: i = 1, j = 2. *)
    assert { 0 <= 1 <= 2 < length a };
    assert { a[1] = 3 };
    assert { a[2] = 2 };
    assert { not (a[1] <= a[2]) };

    assert { not (sorted_array a) }

end
