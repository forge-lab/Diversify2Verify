module Count_Occurrences_Array_Spec

  use int.Int
  use import array.Array
  use import array.Init

  let rec function num_occ_array_from (a: array int) (x: int) (i: int) : int
    requires { 0 <= i <= length a }
    variant  { length a - i }
  =
    if i = length a then 0
    else (if a[i] = x then 1 else 0) + num_occ_array_from a x (i + 1)

  val count_occurrences_array (a: array int) (x: int) : int
    ensures { result = num_occ_array_from a x 0 }

  let lemma check_ex_array_1 () =
    let a = init 5 [|1; 2; 2; 3; 2|] in
    assert { length a = 5 };

    assert { a[0] = 1 };
    assert { a[1] = 2 };
    assert { a[2] = 2 };
    assert { a[3] = 3 };
    assert { a[4] = 2 };

    assert { num_occ_array_from a 2 5 = 0 };
    assert { num_occ_array_from a 2 4 = 1 };
    assert { num_occ_array_from a 2 3 = 1 };
    assert { num_occ_array_from a 2 2 = 2 };
    assert { num_occ_array_from a 2 1 = 3 };
    assert { num_occ_array_from a 2 0 = 3 }

  let lemma check_ex_array_2 () =
    let a = init 4 [|4; 4; 4; 4|] in
    assert { length a = 4 };

    assert { a[0] = 4 };
    assert { a[1] = 4 };
    assert { a[2] = 4 };
    assert { a[3] = 4 };

    assert { num_occ_array_from a 4 4 = 0 };
    assert { num_occ_array_from a 4 3 = 1 };
    assert { num_occ_array_from a 4 2 = 2 };
    assert { num_occ_array_from a 4 1 = 3 };
    assert { num_occ_array_from a 4 0 = 4 }

  let lemma check_ex_array_3 () =
    let a = init 3 [|1; 3; 5|] in
    assert { length a = 3 };

    assert { a[0] = 1 };
    assert { a[1] = 3 };
    assert { a[2] = 5 };

    assert { num_occ_array_from a 2 3 = 0 };
    assert { num_occ_array_from a 2 2 = 0 };
    assert { num_occ_array_from a 2 1 = 0 };
    assert { num_occ_array_from a 2 0 = 0 }

end
