module Count_Occurrences_Array_Imperative_Implementation

  use int.Int
  use array.Array
  use array.Init
  use ref.Ref

  let count_occurrences_array (a: array int) (x: int) : int =
    let count = ref 0 in
    for i = 0 to length a - 1 do
      if a[i] = x then
        count := !count + 1
    done;
    !count

  let test_example_1 () : bool =
    let a = init 5 [|1; 2; 2; 3; 2|] in
    let r = count_occurrences_array a 2 in
    r = 3

  let test_example_2 () : bool =
    let a = init 4 [|4; 4; 4; 4|] in
    let r = count_occurrences_array a 4 in
    r = 4

  let test_example_3 () : bool =
    let a = init 3 [|1; 3; 5|] in
    let r = count_occurrences_array a 2 in
    r = 0

  let test_empty () : bool =
    let a = make 0 0 in
    let r = count_occurrences_array a 2 in
    r = 0

  let test_singleton_present () : bool =
    let a = init 1 [|7|] in
    let r = count_occurrences_array a 7 in
    r = 1

  let test_singleton_absent () : bool =
    let a = init 1 [|7|] in
    let r = count_occurrences_array a 3 in
    r = 0

  let test_negative_values () : bool =
    let a = init 5 [|-1; 2; -1; 3; -1|] in
    let r = count_occurrences_array a (-1) in
    r = 3

  let run_tests () : bool =
    if test_example_1 () then
    if test_example_2 () then
    if test_example_3 () then
    if test_empty () then
    if test_singleton_present () then
    if test_singleton_absent () then
    if test_negative_values () then
      true
    else false
    else false
    else false
    else false
    else false
    else false
    else false

end
