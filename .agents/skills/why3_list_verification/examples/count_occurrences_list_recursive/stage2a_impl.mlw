module Count_Occurrences_List_Recursive_Implementation

  use int.Int
  use list.List

  let rec count_occurrences_list (l: list int) (x: int) : int
    variant { l }
  =
    match l with
    | Nil -> 0
    | Cons y ys ->
        (if y = x then 1 else 0) + count_occurrences_list ys x
    end

  let test_example_1 () : bool =
    let l = Cons 1 (Cons 2 (Cons 2 (Cons 3 (Cons 2 Nil)))) in
    count_occurrences_list l 2 = 3

  let test_example_2 () : bool =
    let l = Cons 4 (Cons 4 (Cons 4 (Cons 4 Nil))) in
    count_occurrences_list l 4 = 4

  let test_example_3 () : bool =
    let l = Cons 1 (Cons 3 (Cons 5 Nil)) in
    count_occurrences_list l 2 = 0

  let test_empty () : bool =
    count_occurrences_list Nil 2 = 0

  let test_singleton_present () : bool =
    count_occurrences_list (Cons 7 Nil) 7 = 1

  let test_singleton_absent () : bool =
    count_occurrences_list (Cons 7 Nil) 3 = 0

  let test_negative_values () : bool =
    let l = Cons (-1) (Cons 2 (Cons (-1) (Cons 3 (Cons (-1) Nil)))) in
    count_occurrences_list l (-1) = 3

  let run_tests () : bool =
    if test_example_1 () then
    if test_example_2 () then
    if test_example_3 () then
    if test_empty () then
    if test_singleton_present () then
    if test_singleton_absent () then
    if test_negative_values () then
      true
    else false
    else false
    else false
    else false
    else false
    else false
    else false

end
