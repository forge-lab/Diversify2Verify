module Sorted_Array_Spec

  use int.Int
  use array.Array
  use array.Init

  predicate sorted_array (a: array int) =
    forall i j: int.
      0 <= i <= j < length a -> a[i] <= a[j]

  predicate pair_ok (a: array int) (i: int) (j: int) =
    0 <= i <= j < length a -> a[i] <= a[j]

  (* ---------------------------------------------------------------------- *)
  (* Recursive implementation                                                *)
  (* ---------------------------------------------------------------------- *)

  let rec is_sorted_array_from (a: array int) (i: int) : bool
    variant { length a - i }
  =
    if i + 1 >= length a then
      true
    else if a[i] <= a[i + 1] then
      is_sorted_array_from a (i + 1)
    else
      false

  let is_sorted_array (a: array int) : bool =
    is_sorted_array_from a 0

  (* ---------------------------------------------------------------------- *)
  (* Original proof-style contract tests                                     *)
  (* ---------------------------------------------------------------------- *)

  let lemma check_sorted_array_1 () =
    let a = init 4 [|1; 2; 2; 5|] in
    assert { length a = 4 };

    assert { pair_ok a 0 0 };
    assert { pair_ok a 0 1 };
    assert { pair_ok a 0 2 };
    assert { pair_ok a 0 3 };

    assert { pair_ok a 1 1 };
    assert { pair_ok a 1 2 };
    assert { pair_ok a 1 3 };

    assert { pair_ok a 2 2 };
    assert { pair_ok a 2 3 };

    assert { pair_ok a 3 3 };

    assert {
      forall k:int. 0 <= k < length a ->
        k = 0 \/ k = 1 \/ k = 2 \/ k = 3
    };

    assert { sorted_array a }

  let lemma check_sorted_array_2 () =
    let a = init 1 [|7|] in
    assert { length a = 1 };

    assert { pair_ok a 0 0 };

    assert {
      forall k:int. 0 <= k < length a ->
        k = 0
    };

    assert { sorted_array a }

  let lemma check_sorted_array_3 () =
    let a = init 4 [|1; 3; 2; 5|] in
    assert { length a = 4 };

    (* Counterexample: i = 1, j = 2. *)
    assert { 0 <= 1 <= 2 < length a };
    assert { a[1] = 3 };
    assert { a[2] = 2 };
    assert { not (a[1] <= a[2]) };

    assert { not (sorted_array a) }

  (* ---------------------------------------------------------------------- *)
  (* Executable tests                                                        *)
  (* ---------------------------------------------------------------------- *)

  let test_sorted_array_1 () : bool =
    let a = init 4 [|1; 2; 2; 5|] in
    is_sorted_array a

  let test_sorted_array_singleton () : bool =
    let a = init 1 [|7|] in
    is_sorted_array a

  let test_sorted_array_empty () : bool =
    let a = make 0 0 in
    is_sorted_array a

  let test_sorted_array_duplicates () : bool =
    let a = init 5 [|1; 1; 2; 2; 3|] in
    is_sorted_array a

  let test_unsorted_array_middle () : bool =
    let a = init 4 [|1; 3; 2; 5|] in
    not (is_sorted_array a)

  let test_unsorted_array_late () : bool =
    let a = init 5 [|1; 2; 3; 5; 4|] in
    not (is_sorted_array a)

  let run_tests () : bool =
    if test_sorted_array_1 () then
    if test_sorted_array_singleton () then
    if test_sorted_array_empty () then
    if test_sorted_array_duplicates () then
    if test_unsorted_array_middle () then
    if test_unsorted_array_late () then
      true
    else false
    else false
    else false
    else false
    else false
    else false

end
